<idea-plugin>
  <id>org.tatrman.modeler.intellij</id>
  <name>TTR Modeler</name>
  <vendor email="boraperusic@gmail.com" url="https://github.com/Collite/modeler">Collite</vendor>

  <description><![CDATA[
    Editor tooling for the TTR (Tatrman) modeling language: syntax highlighting,
    diagnostics, go-to-definition, find-usages, hover, completion, and rename for
    <code>.ttrm</code> and <code>.ttrg</code> files. Powered by the shared TTR
    language server through <b>LSP4IJ</b>, which is required and installed
    alongside this plugin. Requires Node.js 20+ on your <code>PATH</code> (or set
    the path in <i>Settings → Languages &amp; Frameworks → TTR Modeler</i>).
  ]]></description>

  <change-notes><![CDATA[
    <h3>0.1.0</h3>
    <ul>
      <li>Initial release: text-editor parity with the VS Code extension for
          <code>.ttrm</code> / <code>.ttrg</code> files — syntax highlighting,
          diagnostics, go-to-definition, find-usages, hover, completion, rename —
          via the shared TTR language server through LSP4IJ.</li>
      <li>Node.js discovered on <code>PATH</code> (override in Settings).</li>
    </ul>
  ]]></change-notes>

  <depends>com.intellij.modules.platform</depends>
  <depends>com.redhat.devtools.lsp4ij</depends>
  <depends>org.jetbrains.plugins.textmate</depends>

  <extensions defaultExtensionNs="com.redhat.devtools.lsp4ij">
    <!-- Register the TTR language server (factory builds the stdio process). -->
    <server id="ttrLanguageServer"
            name="TTR Language Server"
            factoryClass="org.tatrman.modeler.intellij.TtrLanguageServerFactory">
      <description><![CDATA[
        Language support for the TTR (Tatrman) modeling language.
      ]]></description>
    </server>

    <!-- Attach the server to .ttrm / .ttrg by file-name pattern, WITHOUT a native
         IntelliJ Language — this preserves TextMate coloration (IJ4). languageId
         matches the LSP document languageId the server keys on (same as the VS
         Code client's documentSelector). -->
    <fileNamePatternMapping patterns="*.ttrm"
                            serverId="ttrLanguageServer"
                            languageId="ttr"/>
    <fileNamePatternMapping patterns="*.ttrg"
                            serverId="ttrLanguageServer"
                            languageId="ttrg"/>
  </extensions>

  <extensions defaultExtensionNs="com.intellij">
    <!-- Ship the TTR TextMate grammars so .ttrm/.ttrg are colored identically to
         VS Code (same grammars). -->
    <textmate.bundleProvider
        implementation="org.tatrman.modeler.intellij.TtrTextMateBundleProvider"/>

    <!-- Application-level settings (Node path, server override, trace level). -->
    <applicationService
        serviceImplementation="org.tatrman.modeler.intellij.settings.TtrSettings"/>
    <applicationConfigurable
        parentId="language"
        instance="org.tatrman.modeler.intellij.settings.TtrSettingsConfigurable"
        id="org.tatrman.modeler.intellij.settings"
        displayName="TTR Modeler"/>

    <!-- Actionable balloons (e.g. missing Node). -->
    <notificationGroup id="TTR Modeler" displayType="BALLOON"/>
  </extensions>
</idea-plugin>
