{
  "name": "@tatrman/package-sdk",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "description": "Open (Apache) SDK contracts for Tatrman domain packages: the manifest schema + proposal-source / canon-function SPIs. The certification lever (FO-23) — a package is authorable from this alone.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./schema/package-manifest.schema.json": "./src/schema/package-manifest.schema.json"
  },
  "files": [
    "dist",
    "src/schema"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {
    "ajv": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
