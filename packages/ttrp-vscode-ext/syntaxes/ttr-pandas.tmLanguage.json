{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "TTR-pandas",
  "scopeName": "source.ttr-pandas",
  "comment": "Bare TTR-pandas program (*.ttr.py): Python highlighting plus the marker-comment line. Hand-written (do not generate) — 20 lines.",
  "patterns": [
    { "include": "#marker" },
    { "include": "source.python" }
  ],
  "repository": {
    "marker": {
      "match": "^\\s*#\\s*ttr:\\s*dialect=pandas.*$",
      "name": "comment.line.marker.ttr-pandas"
    }
  }
}
