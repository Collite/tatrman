{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "TTR-SQL",
  "scopeName": "source.ttr-sql",
  "comment": "Bare TTR-SQL program (*.ttr.sql): SQL highlighting plus the marker-comment line. Hand-written (do not generate) — 20 lines.",
  "patterns": [
    { "include": "#marker" },
    { "include": "source.sql" }
  ],
  "repository": {
    "marker": {
      "match": "^\\s*--\\s*ttr:\\s*dialect=sql.*$",
      "name": "comment.line.marker.ttr-sql"
    }
  }
}
