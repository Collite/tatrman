{
  "name": "@tatrman/grammar",
  "version": "0.0.0",
  "description": "Canonical TTR (Tatrman) ANTLR grammar + extracted property map. Published to public npmjs as @tatrman/grammar (FO ⚑1, A-managed); the 0.0.0 placeholder version is set from the ts-grammar/v<x.y.z> tag at publish time by .github/workflows/publish-ts.yml (see PUBLISHING.md § TypeScript). External publish is gated on Bora's go per FO ⚑2 (validate first).",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Collite/tatrman.git",
    "directory": "packages/grammar"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./grammar": "./src/TTR.g4",
    "./generated/property-map": "./src/generated/property-map.ts"
  },
  "files": [
    "dist",
    "src/TTR.g4",
    "src/generated/property-map.ts",
    "src/generated/version.ts"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "scripts": {
    "prebuild": "tsx scripts/extract-property-map.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "antlr4ng": "^3.0.16"
  }
}
