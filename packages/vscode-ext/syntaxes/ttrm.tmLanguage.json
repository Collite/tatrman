{
  "name": "TTR",
  "fileTypes": [
    "ttr"
  ],
  "scopeName": "source.ttrm",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#literals"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.ttrm",
          "match": "//.*$"
        },
        {
          "name": "comment.block.ttrm",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.ttrm",
          "begin": "\"\"\"",
          "end": "\"\"\""
        },
        {
          "name": "string.quoted.double.ttrm",
          "begin": "\"",
          "end": "\"(?=[^\\\\])",
          "patterns": [
            {
              "name": "constant.character.escape.ttrm",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.ttrm",
          "match": "-?[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "include": "#keyword_control_def_ttrm"
        },
        {
          "include": "#keyword_control_package_ttrm"
        },
        {
          "include": "#keyword_control_import_ttrm"
        },
        {
          "include": "#keyword_declaration_graph_ttrm"
        },
        {
          "include": "#keyword_other_packages_ttrm"
        },
        {
          "include": "#keyword_other_entities_ttrm"
        },
        {
          "include": "#keyword_other_schema_ttrm"
        },
        {
          "include": "#keyword_other_kind_ttrm"
        },
        {
          "include": "#keyword_other_property_ttrm"
        }
      ]
    },
    "literals": {
      "patterns": [
        {
          "include": "#support_type_primitive_ttrm"
        },
        {
          "include": "#constant_language_ttrm"
        },
        {
          "include": "#constant_language_indextype_ttrm"
        },
        {
          "include": "#constant_language_constrainttype_ttrm"
        },
        {
          "include": "#constant_language_querylang_ttrm"
        }
      ]
    },
    "keyword_control_def_ttrm": {
      "patterns": [
        {
          "name": "keyword.control.def.ttrm",
          "match": "\\b(def|schema|model|locale)\\b"
        }
      ]
    },
    "keyword_control_package_ttrm": {
      "patterns": [
        {
          "name": "keyword.control.package.ttrm",
          "match": "\\b(package)\\b"
        }
      ]
    },
    "keyword_control_import_ttrm": {
      "patterns": [
        {
          "name": "keyword.control.import.ttrm",
          "match": "\\b(import)\\b"
        }
      ]
    },
    "keyword_declaration_graph_ttrm": {
      "patterns": [
        {
          "name": "keyword.declaration.graph.ttrm",
          "match": "\\b(graph)\\b"
        }
      ]
    },
    "keyword_other_packages_ttrm": {
      "patterns": [
        {
          "name": "keyword.other.packages.ttrm",
          "match": "\\b(packages)\\b"
        }
      ]
    },
    "keyword_other_entities_ttrm": {
      "patterns": [
        {
          "name": "keyword.other.entities.ttrm",
          "match": "\\b(entities)\\b"
        }
      ]
    },
    "keyword_other_schema_ttrm": {
      "patterns": [
        {
          "name": "keyword.other.schema.ttrm",
          "match": "\\b(db|er|binding|cnc|md|query|world|lexicon)\\b"
        }
      ]
    },
    "keyword_other_kind_ttrm": {
      "patterns": [
        {
          "name": "keyword.other.kind.ttrm",
          "match": "\\b(project|area|map|table|view|column|index|constraint|fk|procedure|entity|attribute|relation|er2db_entity|er2db_attribute|er2db_relation|role|er2cnc_role|drill_map|domain|dimension|hierarchy|measure|cubelet|md2db_cubelet|md2db_domain|md2db_map|md2er_cubelet|engine|executor|storage|term|pattern|example)\\b"
        }
      ]
    },
    "keyword_other_property_ttrm": {
      "patterns": [
        {
          "name": "keyword.other.property.ttrm",
          "match": "\\b(objects|layout|args|display|override|restrict|members|publish|kind|calc|key|hierarchies|levels|via|class|aggregation|validBy|grain|measures|shape|journaling|source|extends|hosts|staging|description|tags|version|primaryKey|columns|indices|constraints|attributes|parameters|resultColumns|definitionSql|type|optional|isKey|searchable|indexed|labelPlural|nameAttribute|codeAttribute|aliases|cardinality|join|target|whereFilter|language|sourceText|length|precision|label|name|direction|displayLabel|valueLabels|roles|search|semantics|keywords|patterns|descriptions|examples|fuzzy|for|forms|match|from|to)\\b"
        }
      ]
    },
    "support_type_primitive_ttrm": {
      "patterns": [
        {
          "name": "support.type.primitive.ttrm",
          "match": "\\b(text|int|float|bool|datetime|string|boolean|number|integer|double|object|list|char|varchar|decimal|date|timestamp)\\b"
        }
      ]
    },
    "constant_language_ttrm": {
      "patterns": [
        {
          "name": "constant.language.ttrm",
          "match": "\\b(null|true|false)\\b"
        }
      ]
    },
    "constant_language_indextype_ttrm": {
      "patterns": [
        {
          "name": "constant.language.indextype.ttrm",
          "match": "\\b(primary|secondary|ordered|btree|fulltext)\\b"
        }
      ]
    },
    "constant_language_constrainttype_ttrm": {
      "patterns": [
        {
          "name": "constant.language.constrainttype.ttrm",
          "match": "\\b(unique|notNull)\\b"
        }
      ]
    },
    "constant_language_querylang_ttrm": {
      "patterns": [
        {
          "name": "constant.language.querylang.ttrm",
          "match": "\\b(SQL|TRANSFORMATION_DSL|DATAFRAME_DSL|REL_NODE)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "punctuation.separator.ttrm",
          "match": "="
        },
        {
          "name": "punctuation.separator.ttrm",
          "match": ":"
        },
        {
          "name": "punctuation.separator.ttrm",
          "match": ","
        },
        {
          "name": "punctuation.separator.ttrm",
          "match": "\\."
        },
        {
          "name": "punctuation.section.braces.ttrm",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.braces.ttrm",
          "match": "\\}"
        },
        {
          "name": "punctuation.section.brackets.ttrm",
          "match": "\\["
        },
        {
          "name": "punctuation.section.brackets.ttrm",
          "match": "\\]"
        },
        {
          "name": "punctuation.section.parens.ttrm",
          "match": "\\("
        },
        {
          "name": "punctuation.section.parens.ttrm",
          "match": "\\)"
        }
      ]
    }
  }
}