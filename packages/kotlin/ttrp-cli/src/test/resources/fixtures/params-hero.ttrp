// PL-P2.S1 (F-4) params-hero — the ttrp-cli hero against the `tatrman`-executor platform
// world, plus runtime params, per-island retries, and an on-failure island. Refs stay
// aligned to the shared erp-project world (right.region, reject-capable `checked` site).

uses world "acme.worlds.platform"

// F-4-i runtime params: a defaulted date (run-date builtin) + a defaulted int.
param run_date: date = @run-date
param min_amount: int = 0

// F-4-ii `retries 2`; the param `run_date` is referenced inside the opaque SQL fragment.
container acc_prep target erp_pg retries 2 """sql
    select account_id, branch_code, region
    from erp.accounts
    where status = 'ACTIVE' and updated >= run_date
"""

container crunch(in accounts, out result, out low, err rejects) target polars {

    raw     = load(files.sales_2026, schema: sales_csv)
    checked = raw -> calc { customer_id = cast(customer as int) }
    sales   = filter(checked, amount > 0 and customer is not null)

    j = join(left: accounts, right: sales,
             on: left.account_id = right.customer
                 and left.branch_code = right.region,
             type: inner)

    sums = j -> aggregate {
                  group by region
                  total   = sum(amount)
                  avg_amt = avg(amount)
                }

    b = branch(sums, total > 100000)

    result  = b.true
    low     = b.false
    rejects = checked.rejects
}

// F-4-iv on-failure island: runs iff `crunch` failed. Consumes both params (SQL fragment).
container salvage target erp_pg on failure of crunch """sql
    select account_id
    from erp.accounts
    where updated >= run_date and threshold >= min_amount
"""

acc_prep -> crunch.accounts
crunch.result  -> display(main_result)
crunch.low     -> store(files.low_regions)
crunch.rejects -> store(files.join_errors)
