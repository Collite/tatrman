# MD dot-path — float/path disambiguation conformance table (contracts §1.3, D14/D15).
# Format: <expression source> :: <kind>   where kind ∈ { literal | path | binop }.
#   literal — parses as a numeric literal (float or int)
#   path    — parses as an mdPath
#   binop   — a binary expression whose operands include a path (STAR is the operator, not path-internal)
# Rows marked (guard) already parse today and MUST stay green + byte-identical (zero behaviour change).

# --- floats (contracts §1.3 table, row 1) ---
.25                         :: literal
25.                         :: literal
2025.06                     :: literal
12.5                        :: literal
2025 . 06                   :: literal
# (guard) shapes legal before the NUMBER→INT split — must not regress:
100000                      :: literal
2025                        :: literal

# --- paths (contracts §1.3 table, rows 2–3) ---
sales.2025.06               :: path
2025.06.sales               :: path
2025.06.15                  :: path
sales.{Kaufland, Lidl}.net  :: path
sales.2024..2026.net        :: path
sales."Kaufland K123".net   :: path

# --- STAR binds as operator outside path position (contracts §1.3 table, row 4) ---
x * sales.2025.net          :: binop
