// er-flavored hero (D-a sub-2) â€” erâ†’db early rewrite with mandatory provenance (E-d).
//
// The full design-doc er-hero (06-model-binding-options.md Â§"The er-flavored hero
// variant"): `customer` â‹ˆ `sales_txn` on the modeled `relation customer_sales`, whose
// join key IS the join condition. The shared erp-project fixture now binds the er tier
// (T2.1.0): customerâ†’customers, customer.idâ†’customers.id, customer.customerTypeâ†’
// customers.customer_type, sales_txn.{customer,branch,region}â†’SALES_TXN.{â€¦}, and the
// relation carries `join: [{customer.id â†’ sales_txn.customer}]`. So `on: relation
// customer_sales` synthesizes the port-qualified condition `left.id = right.CUSTOMER`.
// (`customer.segment` is left unbound â€” the relocated RES-005 seed.)

import erp.er.*                              // short entity names (package-derived kinds)

container crunch(out result, err rejects) target polars {

    c = load(customer)                       // er entity â†’ er2db â†’ customers (provenance)
    c = filter(c, customerType = 'retail')   // er attr customerType â†’ customer_type (provenance)

    s = load(sales_txn)                      // er entity â†’ er2db â†’ SALES_TXN (provenance)

    j = join(left: c, right: s,
             on: relation customer_sales)    // the modeled relation IS the join condition

    result = j -> aggregate {
                    group by region
                    total = sum(amount)
                  }
    rejects = j.rejects
}
