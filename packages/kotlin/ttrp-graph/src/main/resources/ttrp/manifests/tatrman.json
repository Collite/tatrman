{
  "manifestVersion": 1,
  "id": "tatrman",
  "kind": "EXECUTION",
  "type": "tatrman",
  "controls": ["FS", "SS"],
  "parallelism": "WAVE",
  "invocations": [
    { "targetEngineType": "postgres", "delivery": "psql", "command": "psql -v ON_ERROR_STOP=1 --no-psqlrc -f" },
    { "targetEngineType": "polars", "delivery": "python3", "interpreter": "python3.13", "packages": { "polars": ">=1" } },
    { "targetEngineType": "display", "delivery": "file-drop" }
  ],
  "executor": {
    "params": true,
    "paramTypes": ["string", "int", "decimal", "date", "datetime", "bool"],
    "builtins": ["run-date"],
    "onFailure": true,
    "retries": true
  }
}
