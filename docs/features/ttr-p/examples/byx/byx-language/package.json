{
  "name": "byx-language",
  "displayName": "Byx Language",
  "description": "Language support for the Byx language.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.73.1"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:byx"
  ],
  "main": "./client/out/extension",
  "contributes": {
    "languages": [
      {
        "id": "byx",
        "aliases": [
          "Byx",
          "byx"
        ],
        "extensions": [
          ".byx"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "byx",
        "scopeName": "source.byx",
        "path": "./syntaxes/byx.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          {
            "scope": "meta.type.byx",
            "settings": {
              "foreground": "#96e4a9",
              "fontStyle": "bold"
            }
          },
          {
            "scope": "keyword.helper.byx",
            "settings": {
              "foreground": "#ddafcf"
            }
          },
          {
            "scope": "entity.name.byx",
            "settings": {
              "foreground": "#4165a8",
              "fontStyle": "bold"
            }
          }
        ]
      },
      "editor.wordBasedSuggestions": false,
      "editor.suggest.showKeywords": true,
      "editor.suggest.showFields": true
    },
    "configuration": {
      "type": "object",
      "title": "Example configuration",
      "properties": {
        "byxLanguageServer.maxNumberOfProblems": {
          "scope": "resource",
          "type": "number",
          "default": 100,
          "description": "Controls the maximum number of problems produced by the server."
        },
        "byxLanguageServer.trace.server": {
          "scope": "window",
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the language server."
        }
      }
    }
  },
  "scripts": {
    "build": "ts-node scripts/build.ts",
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -b",
    "watch": "tsc -b -w",
    "lint": "eslint ./client/src ./server/src --ext .ts,.tsx",
    "postinstall": "cd client && npm install && cd ../server && npm install && cd .."
  },
  "dependencies": {
    "@types/fs-extra": "^9.0.13",
    "@types/mocha": "^10.0.1",
    "@types/node": "^16.14.2",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "axios": "^1.2.1",
    "eslint": "^8.29.0",
    "fs-extra": "^11.1.0",
    "mocha": "^10.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^4.9"
  }
}