{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tatrman.org/schemas/ttrp/authoring-context/v1",
  "title": "TTR-P authoring-context bundle (v1)",
  "description": "Deterministic, prompt-ready serialization of a TTR-P document's authoring context (contracts \u00a77, C4-d/S8). Returned by ttrp/authoringContext; consumed by assist hosts + agents, paired with ttrp/validate in a generate\u2192validate\u2192repair loop. Every object is closed. The schema is FINAL; some content grows in later phases (capability node/function rosters, model objects, TTR-SQL/TTR-B grammar rosters, TTR-B diagnostics) \u2014 the fields are present now with the shapes pinned here.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "world",
    "capabilities",
    "modelObjects",
    "grammar",
    "diagnostics"
  ],
  "properties": {
    "version": {
      "const": 1
    },
    "world": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "engines",
        "executors",
        "storages"
      ],
      "properties": {
        "qname": {
          "type": [
            "string",
            "null"
          ]
        },
        "fingerprint": {
          "type": [
            "string",
            "null"
          ]
        },
        "engines": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/instance"
          }
        },
        "executors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/instance"
          }
        },
        "storages": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "staging",
              "rls"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "staging": {
                "type": "boolean"
              },
              "rls": {
                "type": "boolean"
              }
            }
          }
        },
        "staging": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "engines"
      ],
      "properties": {
        "engines": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "engine",
              "nodes",
              "functions"
            ],
            "properties": {
              "engine": {
                "type": "string"
              },
              "type": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "rejects": {
                "type": "boolean",
                "description": "Whether this engine can produce a rejects stream (RJ-P6). Assist must not offer a rejects tap on an engine where this is false. Additive optional field (schema stays v1)."
              },
              "nodes": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "functions": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "modelObjects": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "schema": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/column"
            }
          }
        }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "imports",
        "variables",
        "portsAtCursor"
      ],
      "properties": {
        "imports": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "variables": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "schema"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/column"
                }
              }
            }
          }
        },
        "portsAtCursor": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "insertionTarget": {
          "type": "object",
          "additionalProperties": false,
          "description": "Cursor-scoped dialect insertion (C4-d-i γ): the dialect the assist emits at this cursor. Host-declared via the position; program scope ⇒ dialect ttrp.",
          "required": [
            "dialect"
          ],
          "properties": {
            "dialect": {
              "type": "string",
              "enum": [
                "ttrp",
                "sql",
                "pandas",
                "ttrb"
              ]
            },
            "containerName": {
              "type": "string"
            },
            "targetEngine": {
              "type": "string"
            }
          }
        }
      }
    },
    "grammar": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "specVersion",
        "statementSummary",
        "dialectRosters"
      ],
      "properties": {
        "specVersion": {
          "type": "integer"
        },
        "statementSummary": {
          "type": "string"
        },
        "dialectRosters": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "ttrp",
            "sql",
            "pandas",
            "ttrb"
          ],
          "properties": {
            "ttrp": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "sql": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "pandas": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "ttrb": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "entryVerbs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "name",
              "params"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "params": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "requiresSemantics": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "callFn": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "form",
            "idKind",
            "purity",
            "resolution"
          ],
          "properties": {
            "form": {
              "type": "string"
            },
            "idKind": {
              "type": "string"
            },
            "purity": {
              "type": "string"
            },
            "resolution": {
              "type": "string"
            }
          }
        }
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "area": {
            "type": "string",
            "description": "The AREA segment of TTRP-<AREA>-<NNN> (EQ, SQL, PD, B, CTL, …) — the repair-vocabulary grouping (T7.2.2)."
          },
          "message": {
            "type": "string"
          },
          "suggestedAlternative": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    }
  },
  "$defs": {
    "instance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "type": [
            "string",
            "null"
          ]
        },
        "version": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "column": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "type"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string"
        }
      }
    }
  }
}
