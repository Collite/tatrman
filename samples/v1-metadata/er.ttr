def entity produkt_návštěvy_zákazníka { description: """Evidence produktů spojených s návštěvou zákazníka.
""",
    attributes: [
        def attribute id_produktu_návštěvy_zákazníka { type: int, isKey: true, description: "Unikátní identifikátor produktu v návštěvě zákazníka", },
        def attribute id_návštěvy_zákazníka { type: int, optional: true, description: "Vazba na návštěvu zákazníka", },
        def attribute id_produktu { type: int, optional: true, description: "Vazba na produkt", },
        def attribute význam_produktu { type: int, optional: true, description: "Význam produktu v kanálu = QXXMEZABC.VLVYZNAM_F WHERE VLTYP_NASTAVENI = 21 pro kanál a produkt", },
        def attribute pořadí_produktu { type: int, optional: true, description: "Pořadí produktu v kanálu = XXNOZPRIPRAVA.PORADI_PR", },
        def attribute vyhrazený_prostor { type: int, optional: true, description: "Délkové cm regálu, které jsou vyhrazeny na DM pro daný produkt = XXNOZPRIPRAVA.VYHRAZENO", },
        def attribute rezerva_tržby_produktu { type: int, optional: true, description: "Rezerva tržby (nevyužitá rezerva tržby produktu) = CONVERT(int, ROUND(SUM(QXXNOZPODPROD.HDTRZBA_POTENCIAL_PODPROD), 0))", },
        def attribute výtěžnost_tržby { type: int, optional: true, description: "Výtěžnost tržby v celých % = CONVERT(int, ROUND(SUM(HDTRZBA_12M_PODPROD) / NULLIF(SUM(HDTRZBA_CILOVYNORMATIV_PODPROD), 0) * 100, 0))", },
        def attribute název_produktu { type: text, optional: true, description: "Název produktu = SKUPZBOZI.NAZEV_SKUP_ZBOZI", },
        def attribute distribuce_procent { type: int, optional: true, description: "Distribuční index produktu v celých % = CONVERT(int, 100.0 * SUM(SKORE) / NULLIF(SUM(VYZNAM), 0))", },
        def attribute obsadil_df_cm { type: int, optional: true, description: "Délka regálu obsažená DF za návštěvu a produkt = SUM(QXXNOZPODPROD.MNOBSADIL_DF_CM_PODPROD)", },
        def attribute podíl_df_procent { type: int, optional: true, description: "Podíl DF na vyhrazeném prostoru produktu v celých % = CONVERT(int, ROUND(SUM(MNOBSADIL_DF_CM_PODPROD) / CONVERT(MONEY, NULLIF(VYHRAZENO, 0)) * 100.00, 0))", },
        def attribute tržba_na_cm_produktu { type: text, optional: true, description: "Tržba na cm regálové plochy za návštěvu a produkt [Kč/cm] = SUM ( QXXNOZPODPROD.HDTRZBA_12M_PREP_PODPROD ) / SUM ( QXXNOZPODPROD.MNOBSADIL_DF_CM_PODPROD ) za DM a produkt", },
    ]
}

def entity reklamace { description: """Hlavička reklamace - obchodní doklad pro reklamaci.
""",
    attributes: [
        def attribute id_reklamace { type: int, isKey: true, description: "Unikátní identifikátor reklamace", },
        def attribute číslo_reklamace { type: text, optional: true, description: "Číslo reklamace", },
        def attribute číslo_vratky { type: text, optional: true, description: "Vazba na číslo vratky", },
        def attribute id_dodacího_místa { type: int, optional: true, description: "Vazba na dodací místo", },
        def attribute datum_plnění { type: datetime, optional: true, description: "Datum plnění reklamace", },
        def attribute datum_vystavení { type: datetime, optional: true, description: "Datum vystavení reklamace", },
        def attribute stav_reklamace { type: int, optional: true, description: """Stav reklamace:
 0 = Pořízeno
 1 = K ověření OA
 2 = K ověření OZ
 3 = Ověřeno OZ
 4 = K ověření AG
 5 = Ověřeno AG
 6 = Ověřeno OA
 9 = Čeká na zákazníka
 10 = Uzavřeno
""", valueLabels: { "0": { cs: """Pořízeno
 1 = K ověření OA
 2 = K ověření OZ
 3 = Ověřeno OZ
 4 = K ověření AG
 5 = Ověřeno AG
 6 = Ověřeno OA
 9 = Čeká na zákazníka
 10 = Uzavřeno""" } }, },
    ]
}

def entity reklamace_složka { description: """Složka (položka) reklamace - jednotlivé artikly na reklamaci.
""",
    attributes: [
        def attribute id_složky_reklamace { type: int, isKey: true, description: "Unikátní identifikátor složky reklamace", },
        def attribute id_reklamace { type: int, optional: true, description: "Vazba na hlavičku reklamace", },
        def attribute id_artiklu { type: int, optional: true, description: "Vazba na artikl", },
        def attribute množství { type: float, optional: true, description: "Množství kusů na reklamaci", },
        def attribute cena_za_kus { type: text, optional: true, description: "Cena za měrnou jednotku", },
        def attribute celková_cena { type: text, optional: true, description: "Celková cena položky", },
    ]
}

def entity rezerva_tržby { description: """Výpočet rezervy tržeb a vytěženosti pro dodací místa a podprodukty.
Tabulka XXREZERVA_TRZBY obsahuje všechny sloupce včetně indikačních a výpočtových.
""",
    attributes: [
        def attribute zkratka_dm { type: text, isKey: true, description: "Identifikace dodacího místa", },
        def attribute id_obchodního_kanálu { type: int, isKey: true, description: "Identifikace obchodního kanálu", },
        def attribute id_podproduktu { type: int, isKey: true, description: "Identifikace podproduktu", },
        def attribute dm_s_neúplnými_daty { type: int, optional: true, description: """Indikace, zda-li se jedná o DM s úplnými nebo neúplnými daty:
0 = Ne, 1 = Ano
Hodnota "Ano" nastane, pokud:
  • Dodací místo nemá tržbu 12M: ISNULL(PRODEJE.HDTRZBA_12M_DM, 0) <= 0
  • Nebo první dodávka je < 120 dnů od dnešního dne:
    ISNULL(PRODEJE.DTPRVNI_DOD, CONVERT(Date, GETDATE()))
    BETWEEN DATEADD(DAY, -120, CONVERT(Date, GETDATE())) AND CONVERT(Date, GETDATE())
  • Nebo podíl prodávaných zájmových podproduktů na DM vůči celkovému počtu
    zájmových podproduktů v kanálu je < 25 %:
    CONVERT(MONEY, PRODEJE.POCET_PODPROD_DM) / NULLIF(LISTING.POCET_PODPROD_KANAL, 0) * 100.00 < 25.00
""", valueLabels: { "0": { cs: "Ne" }, "1": { cs: """Ano
Hodnota "Ano" nastane""" } }, },
        def attribute dm_s_evidovanou_konkurencí { type: int, optional: true, description: """Indikace, zda-li je na DM kompletně zaevidovaná konkurence:
0 = Ne, 1 = Ano
Zohledňuje evidovaný vyhrazený prostor v produktu na poslední návštěvě DM
a pokud není, tak se používá délka regálové plochy evidovaná na dodacím místě.
  • Z poslední návštěvy se zjistí celkový počet produktů.
  • Z poslední návštěvy se zjistí počet produktů s evidovanou konkurencí
    (na produktu není evidován <neurčený> dodavatel a <neurčená> značka).
  • Z hlavičky adresy se zjistí délka regálové plochy v metrech
    (SUBJADRADD.DELKA_REGALU * 100 cm/m). Použije se pokud není konkurence
    zaevidovaná na 100 %.
  • Pokud počet vyplněných produktů = počet produktů celkem, vezme se
    hodnota VYHRAZENO, jinak NULL a použije se DELKA_REGALU.
    Pokud celkový výsledek > 0, DM má vyplněnou konkurenci.
WHEN ISNULL(
     CASE
          WHEN EVIDENCE_KONKURENCE.KONKURENCE_PRODUKTY_CELKEM
               = EVIDENCE_KONKURENCE.KONKURENCE_PRODUKTY_VYPLNENO
          THEN NULLIF(EVIDENCE_KONKURENCE.VYHRAZENO, 0)
     END,
     DELKA_REGALU.VYHRAZENO
) > 0 THEN 1
""", valueLabels: { "0": { cs: "Ne" }, "1": { cs: """Ano
Zohledňuje evidovaný vyhrazený prostor v produktu na poslední návštěvě DM
a pokud není""" } }, },
        def attribute datum_první_dodávky { type: datetime, optional: true, description: "Datum první dodávky na dodacím místě: MIN(XXPRODEJE.DTPRVNI_DOD)", },
        def attribute počet_podproduktů_dm { type: int, optional: true, description: """Počet zájmových podproduktů, které na dodacím místě mají tržbu 12M > 0:
COUNT(DISTINCT CASE WHEN XXPRODEJE.HDTRZBA_12M > 0 AND QXXMEZABC.VLVYZNAM_F > 0
      THEN XXPRODEJE.IDXXPODSKUPZBOZI END)
""", },
        def attribute počet_podproduktů_kanál { type: int, optional: true, description: """Počet zájmových podproduktů v kanálu s aktivním listingem k dnešnímu dni:
COUNT(DISTINCT ZBOZIADD.IDXXPODSKUPZBOZI) kde QXXMEZABC.VLVYZNAM_F > 0
""", },
        def attribute konkurence_produkty_celkem { type: int, optional: true, description: "Počet produktů poslední návštěvy: COUNT(DISTINCT XXKONKNADM.IDSKUPZBOZI)", },
        def attribute konkurence_produkty_vyplněno { type: int, optional: true, description: """Počet produktů poslední návštěvy s evidovanou konkurencí:
COUNT(DISTINCT CASE
     WHEN XXKONKURENT_D.NAZEV_KONKURENTA <> '(neurčený)'
          AND XXKONKURENT_Z.NAZEV_KONKURENTA <> '(neurčená)'
     THEN XXKONKNADM.IDSKUPZBOZI
END)
""", },
        def attribute vyhrazený_prostor { type: int, optional: true, description: """Celkový vyhrazený prostor na dodacím místě:
ISNULL(
     CASE
          WHEN EVIDENCE_KONKURENCE.KONKURENCE_PRODUKTY_CELKEM
               = EVIDENCE_KONKURENCE.KONKURENCE_PRODUKTY_VYPLNENO
          THEN NULLIF(EVIDENCE_KONKURENCE.VYHRAZENO, 0)
     END,
     DELKA_REGALU.VYHRAZENO
)
""", },
        def attribute tržba_12m_podproduktu { type: text, optional: true, description: "Skutečná tržba podproduktu na DM za posledních 12 měsíců", },
        def attribute normativ_tržby { type: text, optional: true, description: "Cílová (normativní) tržba podproduktu na DM — určuje očekávanou úroveň prodejů. Zdroj: QXXMEZABC.HDNORMATIV_TRZBY_F (VLTYP_NASTAVENI = 22), jen zájmové podprodukty v kanálu.", },
        def attribute celková_tržba_na_dm { type: text, optional: true, description: "SUM ( HDTRZBA_12M_PODPROD ) Celkový součet prodejů za dodací místo", },
        def attribute celkový_normativ_tržby_dm { type: text, optional: true, description: "SUM ( HDNORMATIV_TRZBY ) Celkový součet normativů tržby za dodací místo", },
        def attribute normativní_tržba { type: text, optional: true, description: "Výpočtové pole podle pravidla: HDNORMATIV_TRZBY / 100 * ( HDTRZBA_12M_DM / ( HDNORMATIV_TRZBY_DM / 100 ) )", },
        def attribute nadnormativní_podprodukt { type: int, optional: true, description: "Výpočtové pole: 1 = nadnormativní (HDTRZBA_12M_PODPROD >= HDTRZBA_NORMATIV), 0 = pod normou, NULL = nedefinováno", valueLabels: { "1": { cs: "nadnormativní (HDTRZBA_12M_PODPROD >= HDTRZBA_NORMATIV" }, "0": { cs: "pod normou" } }, },
        def attribute upravená_nadnormativní_tržba { type: text, optional: true, description: "Výpočtové pole podle pravidla: WHEN ISNULL ( HDTRZBA_NORMATIV, 0) <= 0 THEN 0 WHEN HDTRZBA_12M_PODPROD > HDTRZBA_NORMATIV AND HDTRZBA_12M_PODPROD / HDTRZBA_NORMATIV > 1.33 THEN HDTRZBA_NORMATIV * 1.33 ELSE HDTRZBA_12M_PODPROD", },
        def attribute celková_potenciální_tržba_dm { type: text, optional: true, description: "WHEN ISNULL(HDTRZBA_12M_PODPROD,0) = 0 THEN 0 ELSE SUM(HDTRZBA_NORMATIV_UPRAV) pro VLPODPROD_NADNORMATIV = 1 za dodací místo / SUM(HDNORMATIV_TRZBY / 100) pro VLPODPROD_NADNORMATIV = 1 za dodací místo", },
        def attribute cílový_normativ_podproduktu { type: text, optional: true, description: "HDTRZBA_POTENCIAL_DM * HDNORMATIV_TRZBY / 100 — cílová tržba podproduktu odvozená z celkového potenciálu DM", },
        def attribute rezerva_tržby_podproduktu { type: text, optional: true, description: "HDTRZBA_CILOVYNORMATIV_PODPROD - HDTRZBA_12M_PODPROD — rezerva tržby podproduktu (kladná = prostor pro růst, záporná = překonává cíl)", },
        def attribute výtěžnost_procent { type: text, optional: true, description: "HDTRZBA_12M_PODPROD / HDTRZBA_CILOVYNORMATIV_PODPROD * 100 zaokrouhlené na 1 desetinné číslo", },
    ]
}

