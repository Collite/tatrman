def entity vratka_složka { description: """Složka (položka) vratky - jednotlivé artikly na vratce.
⚠ Tabulka QZBOZSDOK je sdílená pro složky všech typů dokladů.
Příslušnost ke konkrétnímu dokladu se určuje JOINem na hlavičku (IDHDOK).
Pravidlo: Vždy použij JOIN na příslušnou hlavičku dokladu, nikdy nedotazuj QZBOZSDOK samostatně.
""",
    attributes: [
        def attribute id_složky_vratky { type: int, isKey: true, description: "Unikátní identifikátor složky vratky", },
        def attribute id_vratky { type: int, optional: true, description: "Vazba na hlavičku vratky", },
        def attribute id_artiklu { type: int, optional: true, description: "Vazba na artikl", },
        def attribute množství { type: float, optional: true, description: "Vrácené množství kusů", },
        def attribute cena_za_kus { type: text, optional: true, description: "Cena za měrnou jednotku", },
        def attribute celková_cena { type: text, optional: true, description: "Celková cena položky", },
    ]
}

def entity výtěžnost_regálu { description: """Výtěžnost regálové plochy pro dodací místo a artikl.
Určí se poslední návštěva DM s evidencí distribuce. Ke zjištěným návštěvám
se doplní artikly z XXPLNPOLDISTR (bez prodejních akcí, ISNULL(VLPRODAKCE,0)=0)
a prodeje z XXPRODEJE (kde ISNULL(HDTRZBA_24M,0)>0).
Koeficient roční tržby (HDTRZBA_12M_KOEF, hodnoty 0–3) se stanoví dle data
první dodávky. Přepočtená roční tržba = HDTRZBA_24M / HDTRZBA_12M_KOEF.
Tržba na cm = přepočtená tržba 12M / délka regálu [Kč/cm].
""",
    attributes: [
        def attribute id_obchodního_kanálu { type: int, optional: true, description: "Identifikace obchodního kanálu", },
        def attribute zkratka_dodacího_místa { type: text, isKey: true, description: "Zkratka dodacího místa", },
        def attribute id_produktu { type: int, optional: true, description: "Identifikace produktu", },
        def attribute id_podproduktu { type: int, optional: true, description: "Identifikace podproduktu", },
        def attribute id_artiklu { type: int, isKey: true, description: "Identifikace artiklu", },
        def attribute facing { type: float, optional: true, description: "Počet čelních pozic artiklu na DM (z poslední návštěvy s evidencí distribuce)", },
        def attribute tržba_24_měsíců { type: text, optional: true, description: "Tržba artiklu na DM za posledních 24 měsíců (z XXPRODEJE, kde HDTRZBA_24M > 0)", },
        def attribute první_dodávka { type: datetime, optional: true, description: "Datum první dodávky artiklu na DM", },
        def attribute poslední_dodávka { type: datetime, optional: true, description: "Datum poslední dodávky artiklu na DM", },
        def attribute množství_poslední_dodávky { type: float, optional: true, description: "Množství poslední dodávky artiklu na DM", },
        def attribute koeficient_roční_tržby { type: text, optional: true, description: """Koeficient roční tržby (hodnoty 0–3):
- DTPRVNI_DOD > dnes - 365 dnů → 1
- DTPRVNI_DOD <= dnes - 365 a > dnes - 730 → (počet dnů od DTPRVNI_DOD) / 365
- DTPRVNI_DOD <= dnes - 730 dní → 3
""", },
        def attribute délka_regálu { type: float, optional: true, description: "Délka regálu v cm pro artikl a DM = facing × šířka artiklu", },
        def attribute přepočtená_tržba_12m { type: text, optional: true, description: "Přepočtená roční tržba = HDTRZBA_24M / HDTRZBA_12M_KOEF", },
        def attribute tržba_na_cm { type: text, optional: true, description: "Tržba na cm regálové plochy artiklu na DM [Kč/cm] = HDTRZBA_12M_PREP / MNDELKA_REG_ART", },
    ]
}

def entity výtěžnost_regálu_kanál { description: """Výtěžnost regálové plochy agregovaná za obchodní kanál a artikl.
Pohled agreguje data z QDF_VYTEZNOST_REGALU za kanál a artikl.
Hodnoty se počítají pouze z artiklů, které mají evidovaný facing > 0.
Slouží k určení průměrné výtěžnosti artiklu v kanálu pro artikly
s potenciálem k nabídce.
""",
    attributes: [
        def attribute id_obchodního_kanálu { type: int, isKey: true, description: "Identifikace obchodního kanálu", },
        def attribute id_artiklu { type: int, isKey: true, description: "Identifikace artiklu", },
        def attribute odebírá_počet_dm_kanál { type: int, optional: true, description: "Počet DM v kanálu, které pro artikl mají tržbu 12M > 0", },
        def attribute celkem_počet_dm_kanál { type: int, optional: true, description: "Celkový počet DM v kanálu", },
        def attribute délka_regálu_kanál { type: float, optional: true, description: "Celková délka regálu artiklu v kanálu v cm (SUM, nikoli AVG)", },
        def attribute přepočtená_tržba_12m_kanál { type: text, optional: true, description: "Průměrná přepočtená roční tržba artiklu v kanálu", },
        def attribute tržba_na_cm_kanál { type: text, optional: true, description: "Tržba na cm regálové plochy artiklu v kanálu [Kč/cm] = SUM(HDTRZBA_12M_PREP WHERE facing>0) / NULLIF(SUM(MNDELKA_REG_ART), 0)", },
    ]
}

def entity zakázka { description: """Hlavička zakázky - obchodní doklad pro zákazníka.
""",
    attributes: [
        def attribute id_zakázky { type: int, isKey: true, description: "Unikátní identifikátor zakázky", },
        def attribute číslo_zakázky { type: text, optional: true, description: "Číslo zakázky", },
        def attribute id_dodacího_místa { type: int, optional: true, description: "Vazba na dodací místo", },
        def attribute datum_dodání_zakázky { type: datetime, optional: true, description: "Datum dodání zakázky. Stejný DB sloupec DTZDANITPLN jako datum_plnění na faktuře.", },
        def attribute hodnota_zakázky { type: text, optional: true, description: "Celková hodnota zakázky v Kč (kladná částka)", },
        def attribute stav_zakázky { type: int, optional: true, description: """Stav zakázky:
 -2 = Pořizovaná
 0 = Rozpracovaná
 1 = Normální
 3 = Blokovaná
 4 = Pozastavená
 6 = Předfakturovaná
 7 = Expedovaná
 8 = K fakturaci
 9 = Vyfakturovaná
 10 = Uzavřená
""", valueLabels: { "2": { cs: """Pořizovaná
 0 = Rozpracovaná
 1 = Normální
 3 = Blokovaná
 4 = Pozastavená
 6 = Předfakturovaná
 7 = Expedovaná
 8 = K fakturaci
 9 = Vyfakturovaná
 10 = Uzavřená""" } }, },
    ]
}

def entity zakázka_složka { description: """Složka (položka) zakázky - jednotlivé artikly na zakázce.
⚠ Tabulka QZBOZSDOK je sdílená pro složky všech typů dokladů.
Příslušnost ke konkrétnímu dokladu se určuje JOINem na hlavičku (IDHDOK).
Pravidlo: Vždy použij JOIN na příslušnou hlavičku dokladu, nikdy nedotazuj QZBOZSDOK samostatně.
""", aliases: ["položka_zakázky", "řádek_zakázky", "složka_dokladu"],
    attributes: [
        def attribute id_složky_zakázky { type: int, isKey: true, description: "Unikátní identifikátor složky zakázky", },
        def attribute id_zakázky { type: int, optional: true, description: "Vazba na hlavičku zakázky", },
        def attribute id_artiklu { type: int, optional: true, description: "Vazba na artikl", },
        def attribute množství { type: float, optional: true, description: "Objednané množství kusů", },
        def attribute cena_za_kus { type: text, optional: true, description: "Cena za měrnou jednotku", },
        def attribute celková_cena { type: text, optional: true, description: "Celková cena položky", },
    ]
}

def entity zásoba_artiklu { description: """Evidence zásob artiklů na skladech.
""",
    attributes: [
        def attribute id_zásoby_artiklu { type: int, isKey: true, description: "Unikátní identifikátor zásoby artiklu na skladě", },
        def attribute id_artiklu { type: int, optional: true, description: "Vazba na artikl", },
        def attribute aktuální_zásoba { type: float, optional: true, description: "Aktuální množství zásoby artiklu na skladě", },
        def attribute datum_doplnění { type: datetime, optional: true, description: "Datum doplnění zásoby artiklu na skladě", },
        def attribute množství_doplnění { type: float, optional: true, description: "Množství doplnění zásoby artiklu na skladě", },
    ]
}

def entity úkol_návštěvy_zákazníka { description: """Evidence úkolů spojených s návštěvou zákazníka.
""",
    attributes: [
        def attribute id_úkolu_návštěvy_zákazníka { type: int, isKey: true, description: "Unikátní identifikátor úkolu návštěvy zákazníka", },
        def attribute id_návštěvy_zákazníka { type: int, optional: true, description: "Vazba na návštěvu zákazníka", },
        def attribute popis_úkolu { type: text, optional: true, description: "Popis úkolu", },
    ]
}

def entity účet_účetní_osnovy { description: """Číselník účtů účetní osnovy.
""", labelPlural: "účtů účetní osnovy", aliases: ["účet", "účet osnovy", "účetní osnova"],
    attributes: [
        def attribute id_účtu { type: int, isKey: true, description: "Unikátní identifikátor účtu", },
        def attribute kód_účtu { type: text, optional: true, description: "Kód účtu (např. 013, 501001)", },
        def attribute název_účtu { type: text, optional: true, description: "Název účtu", },
    ]
}

def entity účetní_doklad { description: """Složky obchodních dokladů – řádky dokladů s vazbou na hlavičku, zboží a účetní období.
""", labelPlural: "účetních dokladů", aliases: ["složka dokladu", "doklad", "účetní doklad"],
    attributes: [
        def attribute id_složky_dokladu { type: int, isKey: true, description: "Unikátní identifikátor složky dokladu", },
        def attribute id_hlavičky_dokladu { type: int, optional: true, description: "FK na hlavičku dokladu", },
        def attribute id_typu_dokladu { type: int, optional: true, description: "FK na typ dokladu", },
        def attribute id_subjektu { type: int, optional: true, description: "FK na subjekt (odběratel/dodavatel)", },
        def attribute číslo_dokladu { type: text, optional: true, description: "Číslo dokladu", },
        def attribute datum_zdanitelného_plnění { type: datetime, optional: true, description: "Datum uskutečnění zdanitelného plnění (DUZP)", },
        def attribute text_poznámky { type: text, optional: true, description: "Text hlavičky / poznámka dokladu", },
        def attribute zakázka { type: text, optional: true, description: "Číslo zakázky na složce dokladu", },
        def attribute pořadí_dokladu { type: int, optional: true, description: "Pořadí složky v rámci dokladu", },
        def attribute typ_složky { type: int, optional: true, description: "Typ složky (1=zboží, 2=služba, 3=ostatní, 9=poplatek)", valueLabels: { "1": { cs: "zboží" }, "2": { cs: "služba" }, "3": { cs: "ostatní" }, "9": { cs: "poplatek" } }, },
        def attribute kód_pohybu { type: text, optional: true, description: "Kód pohybu složky (např. FV = Faktura vydaná)", },
        def attribute identifikátor_složky { type: text, optional: true, description: "Kód složky (identifikátor artiklu/zboží)", },
        def attribute název_složky { type: text, optional: true, description: "Název složky (název zboží/služby)", },
        def attribute text_složky { type: text, optional: true, description: "Text složky dokladu", },
        def attribute počet_mj { type: float, optional: true, description: "Počet měrných jednotek", },
        def attribute cena_za_mj { type: text, optional: true, description: "Jednotková cena v Kč", },
        def attribute cena_celkem { type: text, optional: true, description: "Celková cena v Kč", },
    ]
}

def entity účetní_období { description: """Číselník účetních období. Každý záznam reprezentuje jedno účetní období (typicky měsíc)
s vazbou na fiskální období, datem prvního a posledního dne.
""", labelPlural: "účetních období", aliases: ["účetní období", "období", "měsíc"],
    attributes: [
        def attribute id_účetního_období { type: int, isKey: true, description: "Unikátní identifikátor účetního období", },
        def attribute kód_účetního_období { type: text, optional: true, description: "Kód účetního období ve formátu RRRR.MM (např. 2026.04)", },
        def attribute stav_účetního_období { type: int, optional: true, description: "Stav účetního období (0 = otevřené)", valueLabels: { "0": { cs: "otevřené" } }, },
        def attribute první_den_období { type: datetime, optional: true, description: "První den účetního období", },
        def attribute poslední_den_období { type: datetime, optional: true, description: "Poslední den účetního období", },
    ]
}

def entity účetní_středisko { description: """Číselník účetních (nákladových) středisek.
""", labelPlural: "účetních středisek", aliases: ["středisko", "nákladové středisko"],
    attributes: [
