def entity podprodukt { description: """Evidence podproduktů a jejich vlastností.
""",
    attributes: [
        def attribute id_podproduktu { type: int, isKey: true, description: "Unikátní identifikátor podproduktu", },
        def attribute kód_podproduktu { type: text, optional: true, description: "Unikátní kód podproduktu", },
        def attribute název_podproduktu { type: text, optional: true, description: "Obchodní název podproduktu", },
        def attribute id_produktu { type: int, optional: true, description: "Vazba na nadřazený produkt", },
        def attribute pořadí_zadané { type: int, optional: true, description: "Zadané pořadí podproduktu", },
        def attribute význam_zadaný { type: int, optional: true, description: "Zadaný význam podproduktu", },
        def attribute lhůta_poslední_dodávky { type: int, optional: true, description: """Lhůta poslední dodávky ve dnech. Pomocný parametr pro:
- určení termínu poslední dodávky
- výpočet obrátkovosti zásob
""", },
        def attribute objednávkový_list { type: int, optional: true, description: """Identifikátor, zda-li se má artikl v tomto podproduktu tisknout v cenové nabídce DF Tablet:
0 = Ne
1 = Ano
""", valueLabels: { "0": { cs: """Ne
1 = Ano""" } }, },
        def attribute nulové_režie_artiklu { type: int, optional: true, description: """Parametr pro rozpočítání nepřímých nákladů v ABC plán:
0 = Ne
1 = Ano (režie artiklů se na artiklech nerozpouští)
""", valueLabels: { "0": { cs: """Ne
1 = Ano (režie artiklů se na artiklech nerozpouští""" } }, },
        def attribute nulové_režie_zákazníka { type: int, optional: true, description: """Parametr pro rozpočítání nepřímých nákladů v ABC plán:
0 = Ne
1 = Ano (režie zákazníků se na artiklech nerozpouští)
""", valueLabels: { "0": { cs: """Ne
1 = Ano (režie zákazníků se na artiklech nerozpouští""" } }, },
        def attribute produkt_manažer { type: int, optional: true, description: "Produkt manažer odpovědný za podprodukt", },
    ]
}

def entity podprodukt_návštěvy_zákazníka { description: """Evidence podproduktů spojených s návštěvou zákazníka.
VIEW nad XXNOZPODPROD s JOINy na XXNOZPRIPRAVA, XXPODSKUPZBOZI, XXNAVSTEVAOZ
a subquery DISTRIBUCE z XXPLNPOLDISTR (facing, distribuce, obsazení regálu).
Filtr: pouze podprodukty s VLVYZNAM_PODPROD > 0.
Sloupce odvozené z XXPLNPOLDISTR vrací NULL, pokud HDNORMATIV_TRZBY_PODPROD = 0.
""",
    attributes: [
        def attribute id_podproduktu_návštěvy_zákazníka { type: int, isKey: true, description: "Unikátní identifikátor podproduktu v návštěvě zákazníka", },
        def attribute id_produktu_návštěvy_zákazníka { type: int, optional: true, description: "Vazba na produkt spojený s návštěvou zákazníka", },
        def attribute id_podproduktu { type: int, optional: true, description: "Vazba na podprodukt", },
        def attribute pořadí_podproduktu { type: int, optional: true, description: "Pořadí podproduktu v rámci produktu na DM = XXNOZPODPROD.PORADI_PODPROD", },
        def attribute id_návštěvy_zákazníka { type: int, optional: true, description: "Vazba na návštěvu zákazníka = XXNOZPRIPRAVA.IDXXNAVSTEVAOZ (přes JOIN na XXNOZPRIPRAVA)", },
        def attribute normativ_tržby_podproduktu { type: text, optional: true, description: "Normativ tržby podproduktu = XXNOZPODPROD.HDNORMATIV_TRZBY_PODPROD", },
        def attribute význam_podproduktu { type: int, optional: true, description: "Význam podproduktu v kanálu = XXNOZPODPROD.VLVYZNAM_PODPROD", },
        def attribute tržba_12m_podproduktu { type: int, optional: true, description: "Tržba podproduktu na DM za posledních 12 měsíců zaokrouhlená na celé Kč = CONVERT(int, ROUND(XXNOZPODPROD.HDTRZBA_12M_PODPROD, 0))", },
        def attribute rezerva_tržby_podproduktu { type: int, optional: true, description: "Rezerva tržby podproduktu zaokrouhlená na celé Kč = CONVERT(int, ROUND(XXNOZPODPROD.HDTRZBA_POTENCIAL_PODPROD, 0))", },
        def attribute výtěžnost_tržby_podproduktu { type: int, optional: true, description: "Na kolik % aktuální tržba využívá rezervu tržby = CONVERT(int, XXNOZPODPROD.HDTRZBA_VYTEZNOST_PODPROD)", },
        def attribute počet_artiklů_podproduktu { type: int, optional: true, description: "Počet artiklů podproduktu na DM s facingem > 0 = SUM(CASE WHEN ISNULL(XXPLNPOLDISTR.MNFACING,0) > 0 THEN 1 END) z XXPLNPOLDISTR per IDXXNAVSTEVAOZ + IDXXPODSKUPZBOZI. NULL pokud HDNORMATIV_TRZBY_PODPROD = 0.", valueLabels: { "0": { cs: "SUM(CASE WHEN ISNULL(XXPLNPOLDISTR.MNFACING" } }, },
        def attribute distribuce_procent_podproduktu { type: int, optional: true, description: "Distribuce podproduktu na DM v % = CONVERT(int, 100.0 * DISTRIBUCE.SKORE / NULLIF(DISTRIBUCE.VYZNAM, 0)) z XXPLNPOLDISTR. SKORE = SUM(VYZNAM) artiklů se zásobou, bez prodejní akce a s platnou sezónou.", },
        def attribute přepočtená_tržba_12m_podproduktu { type: text, optional: true, description: "Přepočtená tržba podproduktu za 12 měsíců = XXNOZPODPROD.HDTRZBA_12M_PREP_PODPROD", },
        def attribute cílová_normativní_tržba { type: int, optional: true, description: "Plánovaná tržba podproduktu zaokrouhlená na celé Kč = CONVERT(int, ROUND(XXNOZPODPROD.HDTRZBA_CILOVYNORMATIV_PODPROD, 0))", },
        def attribute kód_podproduktu { type: text, optional: true, description: "Kód podproduktu = XXPODSKUPZBOZI.KOD_PODSKUPZBOZI", },
        def attribute název_podproduktu { type: text, optional: true, description: "Název podproduktu = XXPODSKUPZBOZI.NAZEV_PODSKUPZBOZI", },
        def attribute tržba_na_cm_podproduktu { type: text, optional: true, description: "Tržba na cm regálové plochy podproduktu [Kč/cm] = ROUND(XXNOZPODPROD.HDTRZBA_12M_PREP_PODPROD / NULLIF(DISTRIBUCE.MNOBSADIL_DF_CM_PODPROD, 0), 0|2). NULL pokud HDNORMATIV_TRZBY_PODPROD = 0. DISTRIBUCE.MNOBSADIL_DF_CM_PODPROD = SUM(MNARTIKL_SIRKA * MNFACING) z XXPLNPOLDISTR.", },
        def attribute obsadil_df_cm_podproduktu { type: float, optional: true, description: "Délka regálu obsažená DF za podprodukt v cm = SUM(XXPLNPOLDISTR.MNARTIKL_SIRKA * XXPLNPOLDISTR.MNFACING) per IDXXNAVSTEVAOZ + IDXXPODSKUPZBOZI. NULL pokud HDNORMATIV_TRZBY_PODPROD = 0.", },
        def attribute přepočtená_tržba_12m_dm { type: text, optional: true, description: "Přepočtená tržba 12M za celé dodací místo = SUM(HDTRZBA_12M_PREP_PODPROD) OVER (PARTITION BY IDXXNAVSTEVAOZ)", },
        def attribute obsadil_df_cm_dm { type: float, optional: true, description: "Délka regálu obsazená DF za celé DM v cm = SUM(MNOBSADIL_DF_CM_PODPROD) OVER (PARTITION BY IDXXNAVSTEVAOZ)", },
        def attribute tržba_na_cm_dm { type: text, optional: true, description: "Tržba na cm regálové plochy celého DM [Kč/cm] = HDTRZBA_12M_PREP_DM / NULLIF(MNOBSADIL_DF_CM_DM, 0)", },
        def attribute obsadil_df_cm_podproduktu_int { type: int, optional: true, description: "Výpočtové pole: CAST(MNOBSADIL_DF_CM_PODPROD AS int)", },
        def attribute podíl_tržby_na_cm_podproduktu { type: text, optional: true, description: "Výpočtové pole: podíl tržby na cm podproduktu vůči DM = CAST(ROUND(100.0 * HDVYTEZNOST_REGALU_PODPROD / NULLIF(HDVYTEZNOST_REGALU_DM, 0), 2) AS DECIMAL(18,2))", },
    ]
}

def entity prodeje { description: """Agregovaná evidence prodejů na úrovni dodacího místa, produktu a artiklu.
Obsahuje kumulativní tržby a data první/poslední dodávky.
""",
    attributes: [
        def attribute id_dodacího_místa { type: int, isKey: true, description: "Identifikace dodacího místa", },
        def attribute id_tržní_skupiny { type: int, optional: true, description: "Identifikace tržní skupiny", },
        def attribute id_obchodního_kanálu { type: int, optional: true, description: "Identifikace obchodního kanálu", },
        def attribute zkratka_dodacího_místa { type: text, optional: true, description: "Zkratka dodacího místa", },
        def attribute id_typ_dodacího_místa { type: int, optional: true, description: "Identifikace typu dodacího místa", },
        def attribute id_produktu { type: int, optional: true, description: "Identifikace produktu", },
        def attribute id_podproduktu { type: int, optional: true, description: "Identifikace podproduktu", },
        def attribute id_artiklu { type: int, isKey: true, description: "Identifikace artiklu", },
        def attribute první_dodávka { type: datetime, optional: true, description: "První dodávka, která nebyla dobropisem", },
        def attribute poslední_dodávka { type: datetime, optional: true, description: "Poslední dodávka, která nebyla dobropisem", },
        def attribute množství_poslední_dodávky { type: float, optional: true, description: "Množství poslední dodávky v kusech", },
        def attribute tržba_24_měsíců { type: text, optional: true, description: "Součet tržeb (prodeje i dobropisy) za posledních 24 měsíců. Bez DPH. Rolling window počítaný dávkovým přepočtem (nikoli od dneška).", },
        def attribute tržba_12_měsíců { type: text, optional: true, description: "Součet tržeb (prodeje i dobropisy) za posledních 12 měsíců. Bez DPH. Rolling window počítaný dávkovým přepočtem (nikoli od dneška).", },
        def attribute počet_kusů_24_měsíců { type: float, optional: true, description: "Součet prodaných kusů (prodeje i dobropisy) za posledních 24 měsíců", },
        def attribute počet_kusů_12_měsíců { type: float, optional: true, description: "Součet prodaných kusů (prodeje i dobropisy) za posledních 12 měsíců", },
    ]
}

def entity prodejní_akce { description: """Evidence prodejních akcí a jejich vlastností.
