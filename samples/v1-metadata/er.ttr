        def attribute manažer_obchodního_kanálu { type: int, optional: true, description: "Identifikace uživatele, který je zodpovědný za tento obchodní kanál", },
        def attribute spočtený_normativ_tržby { type: int, optional: true, description: "Určení přiřazení spočteného normativu tržby pro tento obchodní kanál  (0 = tržní skupina, 1 = obchodní kanál)", valueLabels: { "0": { cs: "tržní skupina" }, "1": { cs: "obchodní kanál" } }, },
        def attribute minimální_počet_sortimentů { type: int, optional: true, description: "Minimální počet sortimentů pro tento obchodní kanál", },
        def attribute podíl_dm_pro_zájmový_artikl_procent { type: text, optional: true, description: "Stanovuje hranici odebírajících dodacích míst kanálu, která musí být splněna pro indikaci zájmového artiklu. Hodnota v procentech (50.00 = 50 %).", valueLabels: { "00": { cs: "50 %" } }, },
    ]
}

