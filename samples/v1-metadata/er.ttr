        def attribute název_střediska { type: text, optional: true, description: "Název střediska", },
        def attribute id_ukazatele { type: int, optional: true, description: "FK na ukazatel manažerského účetnictví (QXXUKAZMU.IDXXUKAZMU)", },
    ]
}

def entity účetní_zápis { description: """Účetní zápisy – jednotlivé řádky účetních dokladů s obraty MD/Dal.
""", labelPlural: "účetních zápisů", aliases: ["účetní zápis", "zápis", "účetní pohyb"],
    attributes: [
        def attribute id_účetního_zápisu { type: int, isKey: true, description: "Unikátní identifikátor účetního zápisu", },
        def attribute id_hlavičky_dokladu { type: int, optional: true, description: "FK na hlavičku účetního dokladu", },
        def attribute id_složky_dokladu { type: int, optional: true, description: "FK na složku účetního dokladu", },
        def attribute id_střediska { type: int, optional: true, description: "FK na účetní středisko (QSTRED_DF.IDSTRED)", },
        def attribute id_účtu { type: int, optional: true, description: "FK na účet účetní osnovy (QUCTOSN_DF.IDUCTOSN)", },
        def attribute id_účetního_období { type: int, optional: true, description: "FK na účetní období (QUCTOBD.IDUCTOBD)", },
        def attribute text_zápisu { type: text, optional: true, description: "Text účetního zápisu", },
        def attribute obrat_md { type: text, optional: true, description: "Obrat strany Má dáti", },
        def attribute obrat_dal { type: text, optional: true, description: "Obrat strany Dal", },
        def attribute účetní_hodnota { type: text, optional: true, description: "Účetní hodnota", },
    ]
}

def relation artikl_navstevy_zakaznika_artikl { description: "Artikl návštěvy zákazníka odkazuje na artikl", from: er.entity.artikl_návštěvy_zákazníka, to: er.entity.artikl, cardinality: { from: "0..*", to: "0..1" }, join: [{ from: er.entity.artikl_návštěvy_zákazníka.id_artiklu, to: er.entity.artikl.id_artiklu }],
}

def relation artikl_navstevy_zakaznika_navsteva_zakaznika { description: "Artikl návštěvy zákazníka patří k návštěvě zákazníka", from: er.entity.artikl_návštěvy_zákazníka, to: er.entity.návštěva_zákazníka, cardinality: { from: "0..*", to: "0..1" }, join: [{ from: er.entity.artikl_návštěvy_zákazníka.id_návštěvy_zákazníka, to: er.entity.návštěva_zákazníka.id_návštěvy_zákazníka }],
}

def relation artikl_navstevy_zakaznika_podprodukt { description: "Artikl návštěvy zákazníka odkazuje na podprodukt", from: er.entity.artikl_návštěvy_zákazníka, to: er.entity.podprodukt, cardinality: { from: "0..*", to: "0..1" }, join: [{ from: er.entity.artikl_návštěvy_zákazníka.id_podproduktu, to: er.entity.podprodukt.id_podproduktu }],
}

def relation artikl_podprodukt { description: "Artikl patří pod nadřazený podprodukt", from: er.entity.artikl, to: er.entity.podprodukt, cardinality: { from: "0..*", to: "0..1" }, join: [{ from: er.entity.artikl.id_podproduktu, to: er.entity.podprodukt.id_podproduktu }],
}

def relation artikl_pro_obchodni_kanal_artikl { description: "Záznam artiklu v obchodním kanálu je navázán na artikl", from: er.entity.artikl_pro_obchodní_kanál, to: er.entity.artikl, cardinality: { from: "0..*", to: "0..1" },
}

def relation artikl_pro_obchodni_kanal_obchodni_kanal { description: "Artikl přiřazený k obchodnímu kanálu ukazuje na daný kanál", from: er.entity.artikl_pro_obchodní_kanál, to: er.entity.obchodní_kanál, cardinality: { from: "0..*", to: "0..1" },
}

def relation artikl_pro_trzni_skupinu_artikl { description: "Záznam artiklu pro tržní skupinu je navázán na artikl", from: er.entity.artikl_pro_tržní_skupinu, to: er.entity.artikl, cardinality: { from: "0..*", to: "0..1" },
}

def relation artikl_pro_trzni_skupinu_trzni_skupina { description: "Artikl přiřazený k tržní skupině vždy odkazuje na cílovou tržní skupinu", from: er.entity.artikl_pro_tržní_skupinu, to: er.entity.tržní_skupina, cardinality: { from: "0..*", to: "0..1" },
}

def relation artikl_produkt { description: "Artikl patří pod nadřazený produkt", from: er.entity.artikl, to: er.entity.produkt, cardinality: { from: "0..*", to: "0..1" }, join: [{ from: er.entity.artikl.id_produktu, to: er.entity.produkt.id_produktu }],
}

def relation denni_vykaz_oz_uzivatel { description: "Denní výkaz OZ patří uživateli (obchodnímu zástupci)", from: er.entity.denní_výkaz_oz, to: er.entity.uživatel, cardinality: { from: "0..*", to: "0..1" }, join: [{ from: er.entity.denní_výkaz_oz.id_obchodního_zástupce, to: er.entity.uživatel.id_uživatele }],
}

def relation dobropis_slozka_artikl { description: "Složka dobropisu obsahuje konkrétní artikl", from: er.entity.dobropis_složka, to: er.entity.artikl, cardinality: { from: "0..*", to: "0..1" }, join: [{ from: er.entity.dobropis_složka.id_artiklu, to: er.entity.artikl.id_artiklu }],
}

def relation dobropis_slozka_dobropis { description: "Složka dobropisu patří k dobropisu", from: er.entity.dobropis_složka, to: er.entity.dobropis, cardinality: { from: "0..*", to: "0..1" }, join: [{ from: er.entity.dobropis_složka.id_dobropisu, to: er.entity.dobropis.id_dobropisu }],
}

def relation dobropis_subjekt { description: "Dobropis patří k zákazníkovi (subjektu)", from: er.entity.dobropis, to: er.entity.subjekt, cardinality: { from: "0..*", to: "0..1" }, join: [{ from: er.entity.dobropis.id_subjektu, to: er.entity.subjekt.id_subjektu }],
}

def relation dodaci_misto_obchodni_zastupce { description: "Dodací místo má přiřazeného obchodního zástupce", from: er.entity.dodací_místo, to: er.entity.uživatel, cardinality: { from: "0..*", to: "0..1" }, join: [{ from: er.entity.dodací_místo.obchodní_zástupce, to: er.entity.uživatel.id_uživatele }],
}

def relation dodaci_misto_subjekt { description: "Dodací místo patří subjektu", from: er.entity.dodací_místo, to: er.entity.subjekt, cardinality: { from: "0..*", to: "0..1" }, join: [{ from: er.entity.dodací_místo.id_subjektu, to: er.entity.subjekt.id_subjektu }],
}

def relation faktura_slozka_artikl { description: "Složka faktury obsahuje konkrétní artikl", from: er.entity.faktura_složka, to: er.entity.artikl, cardinality: { from: "0..*", to: "0..1" }, join: [{ from: er.entity.dobropis_složka.id_artiklu, to: er.entity.artikl.id_artiklu }],
}

def relation faktura_slozka_faktura { description: "Složka faktury patří k faktuře", from: er.entity.faktura_složka, to: er.entity.faktura, cardinality: { from: "0..*", to: "0..1" }, join: [{ from: er.entity.dobropis_složka.id_dobropisu, to: er.entity.dobropis.id_dobropisu }],
}

def relation faktura_subjekt { description: "Faktura patří k zákazníkovi (subjektu)", from: er.entity.faktura, to: er.entity.subjekt, cardinality: { from: "0..*", to: "0..1" }, join: [{ from: er.entity.dobropis.id_subjektu, to: er.entity.subjekt.id_subjektu }],
}

def relation hodnota_ukazatele_období { description: "Hodnota MÚ patří k účetnímu období", from: er.entity.hodnoty_manažerského_účetnictví, to: er.entity.účetní_období, cardinality: { from: "0..*", to: "0..1" }, join: [{ from: er.entity.hodnoty_manažerského_účetnictví.id_účetního_období, to: er.entity.účetní_období.id_účetního_období }],
}

def relation hodnota_ukazatele_ukazatel { description: "Hodnota MÚ patří k ukazateli", from: er.entity.hodnoty_manažerského_účetnictví, to: er.entity.ukazatel_manažerského_účetnictví, cardinality: { from: "0..*", to: "0..1" }, join: [{ from: er.entity.hodnoty_manažerského_účetnictví.id_ukazatele, to: er.entity.ukazatel_manažerského_účetnictví.id_ukazatele }],
}

def relation informace_ke_konkurenci_konkurencni_dodavatel { description: "Informace ke konkurenci odkazuje na konkurenčního dodavatele", from: er.entity.informace_ke_konkurenci, to: er.entity.konkurenční_dodavatel, cardinality: { from: "0..*", to: "0..1" }, join: [{ from: er.entity.informace_ke_konkurenci.id_konkurenčního_dodavatele, to: er.entity.konkurenční_značka.id_konkurenční_značky }],
}

def relation informace_ke_konkurenci_konkurencni_znacka { description: "Informace ke konkurenci odkazuje na konkurenční značku", from: er.entity.informace_ke_konkurenci, to: er.entity.konkurenční_značka, cardinality: { from: "0..*", to: "0..1" }, join: [{ from: er.entity.informace_ke_konkurenci.id_konkurenční_značky, to: er.entity.konkurenční_značka.id_konkurenční_značky }],
}

def relation informace_ke_konkurenci_obchodni_kanal { description: "Informace ke konkurenci odkazuje na obchodní kanál", from: er.entity.informace_ke_konkurenci, to: er.entity.obchodní_kanál, cardinality: { from: "0..*", to: "0..1" }, join: [{ from: er.entity.informace_ke_konkurenci.id_obchodního_kanálu, to: er.entity.obchodní_kanál.id_obchodního_kanálu }],
}

