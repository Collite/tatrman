        def attribute kód_skupiny_uživatelů { type: text, optional: true, description: "Kód skupiny uživatelů (denormalizováno z JOIN na QSKUPUZIV)", },
        def attribute výchozí_skupina_uživatele { type: int, optional: true, description: "Indikuje, zda je tato skupina výchozí pro uživatele (1 = ano, 0 = ne). Uživatel může být členem více skupin, ale pouze jedna může být výchozí.", valueLabels: { "1": { cs: "ano" }, "0": { cs: "ne" } }, },
    ]
}

