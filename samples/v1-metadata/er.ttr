schema er namespace entity

def entity artikl { description: """Evidence všech artiklů a jejich vlastností.
⚠ Artikl patří k produktu přes IDSKUPZBOZI.
Typ artiklu je určen hodnotou VLPODTYP_SLOZ:
  1 = Výrobek
  2 = Zboží
  3 = Materiál
  4 = Polotovar
""", labelPlural: "artiklů", aliases: ["zboží", "položka", "SKU"],
    attributes: [
        def attribute id_artiklu { type: int, isKey: true, description: "Unikátní identifikátor artiklu", },
        def attribute kód_artiklu { type: text, optional: true, description: "Unikátní kód artiklu", },
        def attribute název_artiklu { type: text, optional: true, description: "Obchodní název artiklu", search { searchable: true, fuzzy: true, keywords: { cs: ["název", "jméno"], en: ["name", "title"] } } },
        def attribute typ_artiklu { type: int, optional: true, description: "Typ artiklu (1 = Výrobek, 2 = Zboží, 3 = Materiál, 4 = Polotovar)", valueLabels: { "1": { cs: "Výrobek" }, "2": { cs: "Zboží" }, "3": { cs: "Materiál" }, "4": { cs: "Polotovar" } }, },
        def attribute id_produktu { type: int, optional: true, description: "Vazba na nadřazený produkt", },
        def attribute id_podproduktu { type: int, optional: true, description: "Vazba na nadřazený podprodukt", },
        def attribute stav_artiklu { type: int, optional: true, description: "Status artiklu (pouze hodnoty 0 = aktivní, 1 = neaktivní)", valueLabels: { "0": { cs: "aktivní" }, "1": { cs: "neaktivní" } }, },
    ]
}

def entity artikl_návštěvy_zákazníka { description: """Evidence artiklů spojených s návštěvou zákazníka.
""",
    attributes: [
        def attribute id_artiklu_návštěvy_zákazníka { type: int, isKey: true, description: "Identifikace artiklu v návštěvě", },
        def attribute id_návštěvy_zákazníka { type: int, optional: true, description: "Identifikace návštěvy", },
        def attribute id_artiklu { type: int, optional: true, description: "Identifikace artiklu", },
        def attribute id_podproduktu { type: int, optional: true, description: "Identifikace podproduktu", },
        def attribute zásoba_dnes { type: int, optional: true, description: "Zásoba artiklu k dnešnímu dni na DM (= 0 není, =1 je)", },
        def attribute poslední_dodávka { type: datetime, optional: true, description: "Datum poslední dodávky artiklu (IDZBOZI) na DM (SUBJADR_POZNAMKA) = XXPRODEJE.DTPOSLEDNI_DOD", },
        def attribute množství_poslední_dodávky { type: int, optional: true, description: "Množství poslední dodávky artiklu (IDZBOZI) na DM (SUBJADR_POZNAMKA) = XXPRODEJE.MNPOSLEDNI_DOD", },
        def attribute facing { type: float, optional: true, description: "Počet čelních pozic artiklu na DM. Výchozí hodnota přenesená z předchozí návštěvy, OZ ji může přepsat.", },
        def attribute význam { type: int, optional: true, description: "Význam artiklu = QXXLISTING.VLVYZNAM_F", },
        def attribute sezóna { type: int, optional: true, description: """Indikace artiklu, zda-li v době generování aktivity byl validní pro výpočet distribuce.
Naplnění podle hodnoty QXXPRODKRIVKA.VLPLATI pro prodejní křivku artiklu.
0 = Ne
1 = Ano
""", valueLabels: { "0": { cs: """Ne
1 = Ano""" } }, },
        def attribute šířka_artiklu { type: float, optional: true, description: "Šířka KS artiklu v cm (ISNULL ( XXHODPARZBOZI.HODNOTA_PARZBOZI, 0 ) pro PORADI_TYPPARZBOZI = 2)", },
        def attribute délka_regálu_pro_artikl { type: float, optional: true, description: "Výpočtové pole (XXPLNPOLDISTR.MNARTIKL_SIRKA * XXPLNPOLDISTR.MNFACING)", },
        def attribute počet_kusů_12_měsíců { type: float, optional: true, description: "Počet prodaných kusů (prodeje i dobropisy) za posledních 12 měsíců = XXPRODEJE.MNMNOZSTVI_12M", },
        def attribute tržba_na_cm { type: text, optional: true, description: "Tržba na cm regálové plochy artiklu pro návštěvu = QDF_VYTEZNOST_REGALU.HDVYTEZNOST_REGALU pro dodací místo a artikl", },
        def attribute tržba_na_cm_dm_int { type: text, optional: true, description: "Vypočítaný sloupec v pohledu QXXPLNPOLDISTR_AT. Výtěžnost 1 cm regálu na DM pro artikl. Existuje pouze v CZ aplikaci (SK používá HDVYTEZNOST_REGALU).", },
        def attribute přepočtená_tržba_12m_kanál { type: text, optional: true, description: "Přepočítaná tržba 12 M pro kanál a artikl = QDF_VYTEZNOST_REGALU_KANAL.HDTRZBA_12M_PREP_KANAL pro kanál a artikl", },
        def attribute tržba_na_cm_kanál { type: text, optional: true, description: "Tržba na cm regálové plochy pro kanál a artikl = QDF_VYTEZNOST_REGALU_KANAL.HDVYTEZNOST_REGALU_KANAL pro kanál a artikl", },
        def attribute počet_odebírajících_dm_v_kanálu { type: int, optional: true, description: "Počet DM v kanálu, které pro artikl mají tržbu 12M > 0 = QDF_VYTEZNOST_REGALU_KANAL.ODEBIRA_POCET_DM_KANAL pro kanál a artikl", valueLabels: { "0": { cs: "QDF_VYTEZNOST_REGALU_KANAL.ODEBIRA_POCET_DM_KANAL pro kanál a artikl" } }, },
    ]
}

def entity denní_výkaz_oz { description: """Evidence denních výkazů obchodních zástupců.
""",
    attributes: [
        def attribute id_denního_výkazu_oz { type: int, isKey: true, description: "Unikátní identifikátor denního výkazu obchodního zástupce", },
        def attribute id_obchodního_zástupce { type: int, optional: true, description: "Vazba na obchodního zástupce", },
        def attribute datum_výkazu { type: datetime, optional: true, description: "Datum denního výkazu obchodního zástupce", },
    ]
}

def entity dobropis { description: """Hlavička dobropisu - obchodní doklad pro vrácení peněz zákazníkovi.
""",
    attributes: [
        def attribute id_dobropisu { type: int, isKey: true, description: "Unikátní identifikátor dobropisu", },
        def attribute číslo_dobropisu { type: text, optional: true, description: "Číslo dobropisu", },
        def attribute vratka { type: text, optional: true, description: "Vazba na číslo vratky", },
        def attribute id_subjektu { type: int, optional: true, description: "Vazba na zákazníka (subjekt)", },
        def attribute datum_plnění { type: datetime, optional: true, description: "Datum plnění dobropisu", },
        def attribute datum_vystavení { type: datetime, optional: true, description: "Datum vystavení dobropisu", },
        def attribute datum_splatnosti { type: datetime, optional: true, description: "Datum splatnosti dobropisu", },
        def attribute hodnota_dobropisu { type: text, optional: true, description: "Celková hodnota dobropisu v Kč (záporná částka)", },
        def attribute stav_dobropisu { type: int, optional: true, description: """Stav dobropisu:
 0 = Rozpracovaná
 2 = K tisku
 3 = Vytištěná
 4 = K odeslání
 5 = Odeslaná
 6 = Doručená
 7 = K proplacení
 8 = K zápočtu
 9 = Zamítnuto
 10 = Online szamla
 20 = Storno
""", valueLabels: { "0": { cs: """Rozpracovaná
 2 = K tisku
 3 = Vytištěná
 4 = K odeslání
 5 = Odeslaná
 6 = Doručená
 7 = K proplacení
 8 = K zápočtu
 9 = Zamítnuto
 10 = Online szamla
 20 = Storno""" } }, },
    ]
}

def entity dobropis_složka { description: """Složka (položka) dobropisu - jednotlivé artikly na dobropisu.
⚠ Tabulka QZBOZSDOK je sdílená pro složky všech typů dokladů.
Příslušnost ke konkrétnímu dokladu se určuje JOINem na hlavičku (IDHDOK).
Pravidlo: Vždy použij JOIN na příslušnou hlavičku dokladu, nikdy nedotazuj QZBOZSDOK samostatně.
""",
    attributes: [
        def attribute id_složky_dobropisu { type: int, isKey: true, description: "Unikátní identifikátor složky dobropisu", },
        def attribute id_dobropisu { type: int, optional: true, description: "Vazba na hlavičku dobropisu", },
        def attribute id_artiklu { type: int, optional: true, description: "Vazba na artikl", },
        def attribute množství { type: float, optional: true, description: "Množství kusů na dobropisu", },
        def attribute cena_za_kus { type: text, optional: true, description: "Cena za měrnou jednotku", },
        def attribute celková_cena { type: text, optional: true, description: "Celková cena položky", },
    ]
}

def entity dodací_místo { description: """Evidence dodacích míst subjektů.
""", labelPlural: "dodacích míst", aliases: ["dodací místo", "adresa dodání", "provozovna", "pobočka", "prodejna"],
    attributes: [
        def attribute id_dodacího_místa { type: int, isKey: true, description: "Unikátní identifikátor dodacího místa", },
        def attribute id_subjektu { type: int, optional: true, description: "Vazba na subjekt", },
        def attribute zkratka_dodacího_místa { type: text, optional: true, description: "Zkratka dodacího místa", },
        def attribute město { type: text, optional: true, description: "Město dodacího místa", },
        def attribute ulice { type: text, optional: true, description: "Ulice a číslo popisné dodacího místa", },
        def attribute obchodní_zástupce { type: int, optional: true, description: "Identifikace obchodního zástupce přiřazeného k dodacímu místu", },
        def attribute datum_poslední_návštěvy { type: datetime, optional: true, description: "Datum poslední návštěvy na dodacím místě", },
        def attribute zeměpisná_šířka { type: float, optional: true, description: "Zeměpisná šířka dodacího místa", },
        def attribute zeměpisná_délka { type: float, optional: true, description: "Zeměpisná délka dodacího místa", },
    ]
}

def entity faktura { description: """Hlavička faktury - obchodní doklad pro zákazníka.
""",
    attributes: [
        def attribute id_faktury { type: int, isKey: true, description: "Unikátní identifikátor faktury", },
        def attribute číslo_faktury { type: text, optional: true, description: "Číslo faktury", },
        def attribute zakázka { type: text, optional: true, description: "Vazba na číslo zakázky", },
        def attribute id_subjektu { type: int, optional: true, description: "Vazba na zákazníka (subjekt)", },
        def attribute datum_plnění { type: datetime, optional: true, description: "Datum plnění faktury. Stejný DB sloupec DTZDANITPLN jako datum_dodání na zakázce.", },
        def attribute datum_vystavení { type: datetime, optional: true, description: "Datum vystavení faktury", },
        def attribute datum_splatnosti { type: datetime, optional: true, description: "Datum splatnosti faktury", },
        def attribute hodnota_faktury { type: text, optional: true, description: "Celková hodnota faktury v Kč (kladná částka)", },
        def attribute stav_faktury { type: int, optional: true, description: """Stav faktury:
 0 = Rozpracovaná
 2 = K tisku
 3 = Vytištěná
 4 = K odeslání
 5 = Odeslaná
 6 = Doručená
 7 = K proplacení
 8 = K zápočtu
 9 = Zamítnuto
 10 = Online szamla
 20 = Storno
""", valueLabels: { "0": { cs: """Rozpracovaná
 2 = K tisku
 3 = Vytištěná
 4 = K odeslání
 5 = Odeslaná
 6 = Doručená
 7 = K proplacení
 8 = K zápočtu
 9 = Zamítnuto
 10 = Online szamla
 20 = Storno""" } }, },
    ]
}

def entity faktura_složka { description: """Složka (položka) faktury - jednotlivé artikly na faktuře.
⚠ Tabulka QZBOZSDOK je sdílená pro složky všech typů dokladů.
Příslušnost ke konkrétnímu dokladu se určuje JOINem na hlavičku (IDHDOK).
Pravidlo: Vždy použij JOIN na příslušnou hlavičku dokladu, nikdy nedotazuj QZBOZSDOK samostatně.
""",
    attributes: [
        def attribute id_složky_faktury { type: int, isKey: true, description: "Unikátní identifikátor složky faktury", },
        def attribute id_faktury { type: int, optional: true, description: "Vazba na hlavičku faktury", },
        def attribute id_artiklu { type: int, optional: true, description: "Vazba na artikl", },
        def attribute množství { type: float, optional: true, description: "Fakturované množství kusů", },
        def attribute cena_za_kus { type: text, optional: true, description: "Cena za měrnou jednotku", },
        def attribute celková_cena { type: text, optional: true, description: "Celková cena položky", },
    ]
}

def entity hodnoty_manažerského_účetnictví { description: """Hodnoty ukazatelů manažerského účetnictví za účetní období (plán, skutečnost).
""", labelPlural: "hodnot manažerského účetnictví", aliases: ["hodnoty MÚ", "hodnoty manažerského účetnictví", "plán a skutečnost"],
    attributes: [
        def attribute id_hodnoty { type: int, isKey: true, description: "Unikátní identifikátor záznamu hodnoty", },
        def attribute id_ukazatele { type: int, optional: true, description: "FK na ukazatel manažerského účetnictví (QXXUKAZMU.IDXXUKAZMU)", },
        def attribute id_účetního_období { type: int, optional: true, description: "FK na účetní období (QUCTOBD.IDUCTOBD)", },
        def attribute plán { type: text, optional: true, description: "Plánovaná hodnota za období", },
        def attribute skutečnost { type: text, optional: true, description: "Skutečná hodnota za období", },
        def attribute plán_kumulativně { type: text, optional: true, description: "Plánovaná hodnota kumulativně", },
        def attribute skutečnost_kumulativně { type: text, optional: true, description: "Skutečná hodnota kumulativně", },
    ]
}

def entity informace_ke_konkurenci { description: """Evidence informací ke konkurenci.
""",
    attributes: [
        def attribute id_informace_ke_konkurenci { type: int, isKey: true, description: "Unikátní identifikátor informace ke konkurenci", },
        def attribute id_konkurenčního_dodavatele { type: int, optional: true, description: "Vazba na konkurenčního dodavatele", },
        def attribute id_konkurenční_značky { type: int, optional: true, description: "Vazba na konkurenční značku", },
        def attribute id_tržní_skupiny { type: int, optional: true, description: "Vazba na tržní skupinu", },
        def attribute zjištění { type: text, optional: true, description: "Textový popis zjištění ke konkurenčnímu dodavateli nebo značce", },
        def attribute id_obchodního_kanálu { type: int, optional: true, description: "Vazba na obchodní kanál", },
        def attribute id_produktu { type: int, optional: true, description: "Vazba na produkt", },
        def attribute id_podproduktu { type: int, optional: true, description: "Vazba na podprodukt", },
        def attribute typ_informace { type: int, optional: true, description: """Typ informace o konkurenci:
10 = Zjištění dodavatel
20 = Zjištění značka
30 = Povolená kombinace
40 = Zájmový konkurent
""", valueLabels: { "10": { cs: """Zjištění dodavatel
20 = Zjištění značka
30 = Povolená kombinace
40 = Zájmový konkurent""" } }, },
        def attribute vlastnost_informace { type: int, optional: true, description: """Vlastnost pro typ informace o konkurenci:
-1 = Nelze vybrat
0 = Neutrální zjištění
10 = Silné stránky
11 = Slabé stránky
20 = Výhody
21 = Nevýhody
""", valueLabels: { "1": { cs: """Nelze vybrat
0 = Neutrální zjištění
10 = Silné stránky
11 = Slabé stránky
20 = Výhody
21 = Nevýhody""" } }, },
        def attribute oblast_informace { type: int, optional: true, description: """Oblast pro typ informace o konkurenci:
-1 = Nelze vybrat
10 = Nabízený sortiment
20 = Cenová politika
30 = Marketingová podpora
40 = Prodejní servis
50 = Logistický servis
""", valueLabels: { "1": { cs: """Nelze vybrat
10 = Nabízený sortiment
20 = Cenová politika
30 = Marketingová podpora
40 = Prodejní servis
50 = Logistický servis""" } }, },
        def attribute platnost_od { type: datetime, optional: true, description: "Platnost informace od", },
        def attribute platnost_do { type: datetime, optional: true, description: "Platnost informace do", },
        def attribute aktualizováno { type: datetime, optional: true, description: "Datum poslední změny na řádku", },
    ]
}

def entity konkurence_návštěvy_zákazníka { description: """Evidence konkurence spojené s návštěvou zákazníka.
""",
    attributes: [
        def attribute id_konkurence_návštěvy_zákazníka { type: int, isKey: true, description: "Unikátní identifikátor konkurence v návštěvě zákazníka", },
        def attribute id_návštěvy_zákazníka { type: int, optional: true, description: "Identifikace návštěvy zákazníka", },
        def attribute id_produktu { type: int, optional: true, description: "Identifikace produktu", },
        def attribute id_konkurenčního_dodavatele { type: int, optional: true, description: "Identifikace konkurenčního dodavatele = XXKONKNADM.IDXXKONKURENT_D", },
        def attribute id_konkurenční_značky { type: int, optional: true, description: "Identifikace konkurenční značky = XXKONKNADM.IDXXKONKURENT_Z", },
        def attribute obsadil_konkurent_cm { type: int, optional: true, description: "Délkové cm regálu, které zabírá konkurent a značka", },
        def attribute podíl_konkurenta_procent { type: int, optional: true, description: "Podíl konkurenta v procentech", },
    ]
}

def entity konkurenční_dodavatel { description: """Evidence konkurenčních dodavatelů a jejich vlastností.
⚠ Tabulka QXXKONKURENT je sdílená pro dodavatele i značky — rozlišení přes WHERE VLTYP_KONK.
Pro JOIN z informace_ke_konkurenci použij FK IDXXKONKURENT_D (dodavatel) nebo IDXXKONKURENT_Z (značka).
""",
    attributes: [
        def attribute id_konkurenčního_dodavatele { type: int, isKey: true, description: "Unikátní identifikátor konkurenčního dodavatele", },
        def attribute název_konkurenčního_dodavatele { type: text, optional: true, description: "Název konkurenčního dodavatele", },
        def attribute typ_konkurence { type: int, optional: true, description: "Typ konkurence (1 = Dodavatel aktivní, 11 = Dodavatel neaktivní)", valueLabels: { "1": { cs: "Dodavatel aktivní" }, "11": { cs: "Dodavatel neaktivní" } }, },
    ]
}

def entity konkurenční_značka { description: """Evidence konkurenčních značek a jejich vlastností.
⚠ Tabulka QXXKONKURENT je sdílená pro dodavatele i značky — rozlišení přes WHERE VLTYP_KONK.
Pro JOIN z informace_ke_konkurenci použij FK IDXXKONKURENT_D (dodavatel) nebo IDXXKONKURENT_Z (značka).
""",
    attributes: [
        def attribute id_konkurenční_značky { type: int, isKey: true, description: "Unikátní identifikátor konkurenční značky", },
        def attribute název_konkurenční_značky { type: text, optional: true, description: "Název konkurenční značky", },
        def attribute typ_konkurence { type: int, optional: true, description: "Typ konkurence (0 = Značka aktivní, 10 = Značka neaktivní)", valueLabels: { "0": { cs: "Značka aktivní" }, "10": { cs: "Značka neaktivní" } }, },
    ]
}

def entity návštěva_zákazníka { description: """Evidence návštěv zákazníků obchodními zástupci.
""",
    attributes: [
        def attribute id_návštěvy_zákazníka { type: int, isKey: true, description: "Unikátní identifikátor návštěvy zákazníka", },
        def attribute id_denního_výkazu_obchodního_zástupce { type: int, optional: true, description: "Vazba na denní výkaz obchodního zástupce", },
        def attribute id_obchodního_zástupce { type: int, optional: true, description: "Vazba na obchodního zástupce", },
        def attribute jméno_obchodního_zástupce { type: text, optional: true, description: "Jméno obchodního zástupce", },
        def attribute id_dodacího_místa { type: int, optional: true, description: "Vazba na dodací místo zákazníka", },
        def attribute zkratka_dodacího_místa { type: text, optional: true, description: "Zkratka dodacího místa (denormalizováno z QSUBJADR_DF)", },
        def attribute datum_návštěvy { type: datetime, optional: true, description: "Datum návštěvy zákazníka", },
        def attribute typ_návštěvy { type: int, optional: true, description: """Typ návštěvy zákazníka:
0 = běžná
1 = kontrola
2 = ostatní
3 = bez evidence
4 = aktivita
5 = objednávka
6 = objednávka NT
Výchozí filtr pro "počet návštěv": typ IN (0, 1, 2, 4) — bez typů 3 (bez evidence), 5 a 6 (objednávky).
""", valueLabels: { "0": { cs: """běžná
1 = kontrola
2 = ostatní
3 = bez evidence
4 = aktivita
5 = objednávka
6 = objednávka NT
Výchozí filtr pro "počet návštěv": typ IN (0""" } }, },
        def attribute stav_návštěvy { type: int, optional: true, description: """Stav návštěvy zákazníka:
0 = rozpracovaná (OZ ještě nedokončil návštěvu)
1 = uzavřena (OZ dokončil návštěvu, ale nesplnil všechny úkoly/cíle)
2 = splněna (OZ dokončil návštěvu a splnil všechny úkoly/cíle)
Pro "dokončené návštěvy" použij filtr: stav IN (1, 2).
""", valueLabels: { "0": { cs: "rozpracovaná (OZ ještě nedokončil návštěvu" }, "1": { cs: "uzavřena (OZ dokončil návštěvu" }, "2": { cs: "splněna (OZ dokončil návštěvu a splnil všechny úkoly/cíle" } }, },
    ]
}

def entity obchodní_kanál { description: """Evidence obchodních kanálů a jejich vlastností.
""",
    attributes: [
        def attribute id_obchodního_kanálu { type: int, isKey: true, description: "Unikátní identifikátor obchodního kanálu", },
        def attribute kód_obchodního_kanálu { type: text, optional: true, description: "Unikátní kód obchodního kanálu", },
