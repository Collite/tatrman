package billing

model db schema dbo

def table QCENSKUP_DF { description: """Evidence obchodních kanálů a jejich vlastností.
""", primaryKey: ["id_obchodního_kanálu"],
    search { searchable: true },
    columns: [
        def column IDCENSKUP { type: int, isKey: true, description: "Unikátní identifikátor obchodního kanálu", },
        def column CEN_SKUP { type: text, optional: true, description: "Unikátní kód obchodního kanálu", },
        def column IDSKUPZNACZBOZI { type: int, optional: true, description: "Vazba na tržní skupinu", },
        def column IDUZIVATEL { type: int, optional: true, description: "Identifikace uživatele, který je zodpovědný za tento obchodní kanál", },
        def column VLNORMATIV_TRZBY_S { type: int, optional: true, description: "Určení přiřazení spočteného normativu tržby pro tento obchodní kanál  (0 = tržní skupina, 1 = obchodní kanál)", },
        def column POCETSORT_MIN { type: int, optional: true, description: "Minimální počet sortimentů pro tento obchodní kanál", },
        def column HDPODIL_DM_ZAJM_ARTIKL { type: text, optional: true, description: "Stanovuje hranici odebírajících dodacích míst kanálu, která musí být splněna pro indikaci zájmového artiklu. Hodnota v procentech (50.00 = 50 %).", },
    ]
}

def table QDF_VYTEZNOST_REGALU { description: """Výtěžnost regálové plochy pro dodací místo a artikl.
Určí se poslední návštěva DM s evidencí distribuce. Ke zjištěným návštěvám
se doplní artikly z XXPLNPOLDISTR (bez prodejních akcí, ISNULL(VLPRODAKCE,0)=0)
a prodeje z XXPRODEJE (kde ISNULL(HDTRZBA_24M,0)>0).
Koeficient roční tržby (HDTRZBA_12M_KOEF, hodnoty 0–3) se stanoví dle data
první dodávky. Přepočtená roční tržba = HDTRZBA_24M / HDTRZBA_12M_KOEF.
Tržba na cm = přepočtená tržba 12M / délka regálu [Kč/cm].
""", primaryKey: ["zkratka_dodacího_místa", "id_artiklu"],
    columns: [
        def column IDCENSKUP { type: int, optional: true, description: "Identifikace obchodního kanálu", },
        def column SUBJADR_POZNAMKA { type: text, isKey: true, description: "Zkratka dodacího místa", },
        def column IDSKUPZBOZI { type: int, optional: true, description: "Identifikace produktu", },
        def column IDXXPODSKUPZBOZI { type: int, optional: true, description: "Identifikace podproduktu", },
        def column IDZBOZI { type: int, isKey: true, description: "Identifikace artiklu", },
        def column MNFACING { type: decimal, optional: true, description: "Počet čelních pozic artiklu na DM (z poslední návštěvy s evidencí distribuce)", },
        def column HDTRZBA_24M { type: text, optional: true, description: "Tržba artiklu na DM za posledních 24 měsíců (z XXPRODEJE, kde HDTRZBA_24M > 0)", },
        def column DTPRVNI_DOD { type: date, optional: true, description: "Datum první dodávky artiklu na DM", },
        def column DTPOSLEDNI_DOD { type: date, optional: true, description: "Datum poslední dodávky artiklu na DM", },
        def column MNPOSLEDNI_DOD { type: decimal, optional: true, description: "Množství poslední dodávky artiklu na DM", },
        def column HDTRZBA_12M_KOEF { type: text, optional: true, description: """Koeficient roční tržby (hodnoty 0–3):
- DTPRVNI_DOD > dnes - 365 dnů → 1
- DTPRVNI_DOD <= dnes - 365 a > dnes - 730 → (počet dnů od DTPRVNI_DOD) / 365
- DTPRVNI_DOD <= dnes - 730 dní → 3
""", },
        def column MNDELKA_REG_ART { type: decimal, optional: true, description: "Délka regálu v cm pro artikl a DM = facing × šířka artiklu", },
        def column HDTRZBA_12M_PREP { type: text, optional: true, description: "Přepočtená roční tržba = HDTRZBA_24M / HDTRZBA_12M_KOEF", },
        def column HDVYTEZNOST_REGALU { type: text, optional: true, description: "Tržba na cm regálové plochy artiklu na DM [Kč/cm] = HDTRZBA_12M_PREP / MNDELKA_REG_ART", },
    ]
}

def table QDF_VYTEZNOST_REGALU_KANAL { description: """Výtěžnost regálové plochy agregovaná za obchodní kanál a artikl.
Pohled agreguje data z QDF_VYTEZNOST_REGALU za kanál a artikl.
Hodnoty se počítají pouze z artiklů, které mají evidovaný facing > 0.
Slouží k určení průměrné výtěžnosti artiklu v kanálu pro artikly
s potenciálem k nabídce.
""", primaryKey: ["id_obchodního_kanálu", "id_artiklu"],
    columns: [
        def column IDCENSKUP { type: int, isKey: true, description: "Identifikace obchodního kanálu", },
        def column IDZBOZI { type: int, isKey: true, description: "Identifikace artiklu", },
        def column ODEBIRA_POCET_DM_KANAL { type: int, optional: true, description: "Počet DM v kanálu, které pro artikl mají tržbu 12M > 0", },
        def column CELKEM_POCET_DM_KANAL { type: int, optional: true, description: "Celkový počet DM v kanálu", },
        def column MNDELKA_REG_ART_KANAL { type: decimal, optional: true, description: "Celková délka regálu artiklu v kanálu v cm (SUM, nikoli AVG)", },
        def column HDTRZBA_12M_PREP_KANAL { type: text, optional: true, description: "Průměrná přepočtená roční tržba artiklu v kanálu", },
        def column HDVYTEZNOST_REGALU_KANAL { type: text, optional: true, description: "Tržba na cm regálové plochy artiklu v kanálu [Kč/cm] = SUM(HDTRZBA_12M_PREP WHERE facing>0) / NULLIF(SUM(MNDELKA_REG_ART), 0)", },
    ]
}

def table QHDOK_FAV_DF { description: """Hlavička dobropisu - obchodní doklad pro vrácení peněz zákazníkovi.
""", primaryKey: ["id_dobropisu"],
    columns: [
        def column IDHDOK { type: int, isKey: true, description: "Unikátní identifikátor dobropisu", },
        def column CIS_DOK { type: text, optional: true, description: "Číslo dobropisu", },
        def column ZAK_HDOK { type: text, optional: true, description: "Vazba na číslo vratky", },
        def column IDSUBJEKT { type: int, optional: true, description: "Vazba na zákazníka (subjekt)", },
        def column DTZDANITPLN { type: date, optional: true, description: "Datum plnění dobropisu", },
        def column DTVYSTAVENO { type: date, optional: true, description: "Datum vystavení dobropisu", },
        def column DTSPLATNO { type: date, optional: true, description: "Datum splatnosti dobropisu", },
        def column HDKUHRADEVAL { type: text, optional: true, description: "Celková hodnota dobropisu v Kč (záporná částka)", },
        def column VLSTAVHDOK { type: int, optional: true, description: """Stav dobropisu:
 0 = Rozpracovaná
 2 = K tisku
 3 = Vytištěná
 4 = K odeslání
 5 = Odeslaná
 6 = Doručená
 7 = K proplacení
 8 = K zápočtu
 9 = Zamítnuto
 10 = Online szamla
 20 = Storno
""", },
    ]
}

def table QHDOK_ZAK_DF { description: """Hlavička reklamace - obchodní doklad pro reklamaci.
""", primaryKey: ["id_reklamace"],
    columns: [
        def column IDHDOK { type: int, isKey: true, description: "Unikátní identifikátor reklamace", },
        def column CIS_DOK { type: text, optional: true, description: "Číslo reklamace", },
        def column JEJICH_CISDOK { type: text, optional: true, description: "Vazba na číslo vratky", },
        def column IDSUBJADRP { type: int, optional: true, description: "Vazba na dodací místo", },
        def column DTZDANITPLN { type: date, optional: true, description: "Datum plnění reklamace", },
        def column DTVYSTAVENO { type: date, optional: true, description: "Datum vystavení reklamace", },
        def column VLSTAVHDOK { type: int, optional: true, description: """Stav reklamace:
 0 = Pořízeno
 1 = K ověření OA
 2 = K ověření OZ
 3 = Ověřeno OZ
 4 = K ověření AG
 5 = Ověřeno AG
 6 = Ověřeno OA
 9 = Čeká na zákazníka
 10 = Uzavřeno
""", },
    ]
}

def table QHISHDOK_DF { description: "Vazba mezi doklady (předchůdce -> následník)", primaryKey: ["id_toku_dokladů"],
    columns: [
        def column IDHISHDOK { type: int, isKey: true, description: "Unikátní identifikátor toku dokladů", },
        def column IDHDOKP { type: int, optional: true, description: "Identifikace předchozího dokladu (např. Objednávka)", },
        def column CIS_DOKP { type: text, optional: true, description: "Číslo předchozího dokladu", },
        def column NAZEV_TYPDOKP { type: text, optional: true, description: "Typ předchozího dokladu (např. Objednávka, Zakázka, Faktura)", },
        def column DTZDANITPLNP { type: date, optional: true, description: "Datum plnění předchozího dokladu", },
        def column STAVP { type: text, optional: true, description: "Stav předchozího dokladu", },
        def column IDHDOKN { type: int, optional: true, description: "Identifikace následného dokladu (např. Faktura)", },
        def column CIS_DOKN { type: text, optional: true, description: "Číslo následného dokladu", },
        def column NAZEV_TYPDOKN { type: text, optional: true, description: "Typ následného dokladu (např. Faktura, Dobropis)", },
        def column DTZDANITPLNN { type: date, optional: true, description: "Datum plnění následného dokladu", },
        def column STAVN { type: text, optional: true, description: "Stav následného dokladu", },
    ]
}

def table QSDOK { description: """Složky obchodních dokladů – řádky dokladů s vazbou na hlavičku, zboží a účetní období.
""", primaryKey: ["id_složky_dokladu"],
    columns: [
        def column IDSDOK { type: int, isKey: true, description: "Unikátní identifikátor složky dokladu", },
        def column IDHDOK { type: int, optional: true, description: "FK na hlavičku dokladu", },
        def column IDTYPDOK { type: int, optional: true, description: "FK na typ dokladu", },
        def column IDSUBJEKT { type: int, optional: true, description: "FK na subjekt (odběratel/dodavatel)", },
        def column CIS_DOK { type: text, optional: true, description: "Číslo dokladu", },
        def column DTZDANITPLN { type: datetime, optional: true, description: "Datum uskutečnění zdanitelného plnění (DUZP)", },
        def column TEXTPOZN { type: text, optional: true, description: "Text hlavičky / poznámka dokladu", },
        def column ZAK_SDOK { type: text, optional: true, description: "Číslo zakázky na složce dokladu", },
        def column PORADI_DOK { type: int, optional: true, description: "Pořadí složky v rámci dokladu", },
        def column VLTYP_SLOZ { type: int, optional: true, description: "Typ složky (1=zboží, 2=služba, 3=ostatní, 9=poplatek)", },
        def column KOD_POHYB { type: text, optional: true, description: "Kód pohybu složky (např. FV = Faktura vydaná)", },
        def column SLOZKA_IDENT { type: text, optional: true, description: "Kód složky (identifikátor artiklu/zboží)", },
        def column NAZEV_ZBOZI { type: text, optional: true, description: "Název složky (název zboží/služby)", },
        def column TEXT_SLOZ { type: text, optional: true, description: "Text složky dokladu", },
        def column MNPOCETMJ { type: decimal, optional: true, description: "Počet měrných jednotek", },
        def column HDJCENAKC { type: text, optional: true, description: "Jednotková cena v Kč", },
        def column HDCCENAKC { type: text, optional: true, description: "Celková cena v Kč", },
    ]
}

def table QSDOK_PDO_DF { description: """Složka (položka) reklamace - jednotlivé artikly na reklamaci.
""", primaryKey: ["id_složky_reklamace"],
