        def column DTDOPLNENI { type: date, optional: true, description: "Datum doplnění zásoby artiklu na skladě", },
        def column MNDOPLNENI { type: decimal, optional: true, description: "Množství doplnění zásoby artiklu na skladě", },
    ]
}

