def table QZBOZI_DF { description: """Evidence všech artiklů a jejich vlastností.
⚠ Artikl patří k produktu přes IDSKUPZBOZI.
Typ artiklu je určen hodnotou VLPODTYP_SLOZ:
  1 = Výrobek
  2 = Zboží
  3 = Materiál
  4 = Polotovar
""", primaryKey: ["id_artiklu"],
    columns: [
        def column IDZBOZI { type: int, isKey: true, description: "Unikátní identifikátor artiklu", },
        def column CIS_ZBOZI { type: text, optional: true, description: "Unikátní kód artiklu", },
        def column NAZEV_ZBOZI { type: text, optional: true, description: "Obchodní název artiklu", search { searchable: true, fuzzy: true } },
        def column VLPODTYP_SLOZ { type: int, optional: true, description: "Typ artiklu (1 = Výrobek, 2 = Zboží, 3 = Materiál, 4 = Polotovar)", },
        def column IDSKUPZBOZI { type: int, optional: true, description: "Vazba na nadřazený produkt", },
        def column IDXXPODSKUPZBOZI { type: int, optional: true, description: "Vazba na nadřazený podprodukt", },
        def column VLSTAVZBOZI { type: int, optional: true, description: "Status artiklu (pouze hodnoty 0 = aktivní, 1 = neaktivní)", },
    ]
}

def table QZBOZSDOK { description: """Složka (položka) dobropisu - jednotlivé artikly na dobropisu.
⚠ Tabulka QZBOZSDOK je sdílená pro složky všech typů dokladů.
Příslušnost ke konkrétnímu dokladu se určuje JOINem na hlavičku (IDHDOK).
Pravidlo: Vždy použij JOIN na příslušnou hlavičku dokladu, nikdy nedotazuj QZBOZSDOK samostatně.
""", primaryKey: ["id_složky_dobropisu"],
    columns: [
        def column IDSDOK { type: int, isKey: true, description: "Unikátní identifikátor složky dobropisu", },
        def column IDHDOK { type: int, optional: true, description: "Vazba na hlavičku dobropisu", },
        def column IDZBOZI { type: int, optional: true, description: "Vazba na artikl", },
        def column MNCELKEMPOCET { type: decimal, optional: true, description: "Množství kusů na dobropisu", },
        def column HDJCENAVAL { type: text, optional: true, description: "Cena za měrnou jednotku", },
        def column HDCCENAVAL { type: text, optional: true, description: "Celková cena položky", },
    ]
}

def table XXKONKINFOTYP { description: """Povolené typy informací o konkurenci.
""", primaryKey: ["id_typu_informace"],
    columns: [
        def column IDXXKONKINFOTYP { type: int, isKey: true, description: "Unikátní identifikátor typu informace o konkurenci", },
        def column VLTYP_INFO { type: int, optional: true, description: """Typ informace o konkurenci:
10 = Zjištění dodavatel
20 = Zjištění značka
30 = Povolená kombinace
40 = Zájmový konkurent
""", },
        def column VLVLASTNOST_INFO { type: int, optional: true, description: """Vlastnost pro typ informace o konkurenci:
-1 = Nelze vybrat
0 = Neutrální zjištění
10 = Silné stránky
11 = Slabé stránky
20 = Výhody
21 = Nevýhody
""", },
        def column VLOBLAST_INFO { type: int, optional: true, description: """Oblast pro typ informace o konkurenci:
-1 =  Nelze vybrat
10 = Nabízený sortiment
20 = Cenová politika
30 = Marketingová podpora
40 = Prodejní servis
50 = Logistický servis
""", },
        def column VLTRZNI_SKUPINA { type: int, optional: true, description: """Tržní skupina pro typ informace o konkurenci:
-1 = Nelze vybrat
0 = Nepovinný
1 = Povinný
""", },
        def column VLKANAL { type: int, optional: true, description: """Obchodní kanál pro typ informace o konkurenci:
-1 = Nelze vybrat
0 = Nepovinný
1 = Povinný
""", },
        def column VLPRODUKT { type: int, optional: true, description: """Produkt pro typ informace o konkurenci:
-1 = Nelze vybrat
0 = Nepovinný
1 = Povinný
""", },
        def column VLPODPRODUKT { type: int, optional: true, description: """Podprodukt pro typ informace o konkurenci:
-1 = Nelze vybrat
0 = Nepovinný
1 = Povinný
""", },
        def column VLDODAVATEL { type: int, optional: true, description: """Dodavatel pro typ informace o konkurenci:
-1 = Nelze vybrat
0 = Nepovinný
1 = Povinný
""", },
        def column VLZNACKA { type: int, optional: true, description: """Značka pro typ informace o konkurenci:
-1 = Nelze vybrat
0 = Nepovinný
1 = Povinný
""", },
        def column VLZJISTENI { type: int, optional: true, description: """Zjištění pro typ informace o konkurenci:
-1 = Nelze vybrat
0 = Nepovinný
1 = Povinný
""", },
    ]
}

def table XXPRODEJE { description: """Agregovaná evidence prodejů na úrovni dodacího místa, produktu a artiklu.
Obsahuje kumulativní tržby a data první/poslední dodávky.
""", primaryKey: ["id_dodacího_místa", "id_artiklu"],
    columns: [
        def column IDSUBJADR { type: int, isKey: true, description: "Identifikace dodacího místa", },
        def column IDSKUPZNACZBOZI { type: int, optional: true, description: "Identifikace tržní skupiny", },
        def column IDCENSKUP { type: int, optional: true, description: "Identifikace obchodního kanálu", },
        def column SUBJADR_POZNAMKA { type: text, optional: true, description: "Zkratka dodacího místa", },
        def column IDXXTYPDODMIST { type: int, optional: true, description: "Identifikace typu dodacího místa", },
        def column IDSKUPZBOZI { type: int, optional: true, description: "Identifikace produktu", },
        def column IDXXPODSKUPZBOZI { type: int, optional: true, description: "Identifikace podproduktu", },
        def column IDZBOZI { type: int, isKey: true, description: "Identifikace artiklu", },
        def column DTPRVNI_DOD { type: date, optional: true, description: "První dodávka, která nebyla dobropisem", },
        def column DTPOSLEDNI_DOD { type: date, optional: true, description: "Poslední dodávka, která nebyla dobropisem", },
        def column MNPOSLEDNI_DOD { type: decimal, optional: true, description: "Množství poslední dodávky v kusech", },
        def column HDTRZBA_24M { type: text, optional: true, description: "Součet tržeb (prodeje i dobropisy) za posledních 24 měsíců. Bez DPH. Rolling window počítaný dávkovým přepočtem (nikoli od dneška).", },
        def column HDTRZBA_12M { type: text, optional: true, description: "Součet tržeb (prodeje i dobropisy) za posledních 12 měsíců. Bez DPH. Rolling window počítaný dávkovým přepočtem (nikoli od dneška).", },
        def column MNMNOZSTVI_24M { type: decimal, optional: true, description: "Součet prodaných kusů (prodeje i dobropisy) za posledních 24 měsíců", },
        def column MNMNOZSTVI_12M { type: decimal, optional: true, description: "Součet prodaných kusů (prodeje i dobropisy) za posledních 12 měsíců", },
    ]
}

def table XXREZERVA_TRZBY { description: """Výpočet rezervy tržeb a vytěženosti pro dodací místa a podprodukty.
Tabulka XXREZERVA_TRZBY obsahuje všechny sloupce včetně indikačních a výpočtových.
""", primaryKey: ["zkratka_dm", "id_obchodního_kanálu", "id_podproduktu"],
    columns: [
        def column SUBJADR_POZNAMKA { type: text, isKey: true, description: "Identifikace dodacího místa", },
        def column IDCENSKUP { type: int, isKey: true, description: "Identifikace obchodního kanálu", },
        def column IDXXPODSKUPZBOZI { type: int, isKey: true, description: "Identifikace podproduktu", },
        def column DM_NEUPLNA_DATA { type: int, optional: true, description: """Indikace, zda-li se jedná o DM s úplnými nebo neúplnými daty:
0 = Ne, 1 = Ano
Hodnota "Ano" nastane, pokud:
  • Dodací místo nemá tržbu 12M: ISNULL(PRODEJE.HDTRZBA_12M_DM, 0) <= 0
  • Nebo první dodávka je < 120 dnů od dnešního dne:
    ISNULL(PRODEJE.DTPRVNI_DOD, CONVERT(Date, GETDATE()))
    BETWEEN DATEADD(DAY, -120, CONVERT(Date, GETDATE())) AND CONVERT(Date, GETDATE())
  • Nebo podíl prodávaných zájmových podproduktů na DM vůči celkovému počtu
    zájmových podproduktů v kanálu je < 25 %:
    CONVERT(MONEY, PRODEJE.POCET_PODPROD_DM) / NULLIF(LISTING.POCET_PODPROD_KANAL, 0) * 100.00 < 25.00
""", },
        def column DM_KONKURENCE_ZAEVIDOVANA { type: int, optional: true, description: """Indikace, zda-li je na DM kompletně zaevidovaná konkurence:
0 = Ne, 1 = Ano
Zohledňuje evidovaný vyhrazený prostor v produktu na poslední návštěvě DM
a pokud není, tak se používá délka regálové plochy evidovaná na dodacím místě.
  • Z poslední návštěvy se zjistí celkový počet produktů.
  • Z poslední návštěvy se zjistí počet produktů s evidovanou konkurencí
    (na produktu není evidován <neurčený> dodavatel a <neurčená> značka).
  • Z hlavičky adresy se zjistí délka regálové plochy v metrech
    (SUBJADRADD.DELKA_REGALU * 100 cm/m). Použije se pokud není konkurence
    zaevidovaná na 100 %.
  • Pokud počet vyplněných produktů = počet produktů celkem, vezme se
    hodnota VYHRAZENO, jinak NULL a použije se DELKA_REGALU.
    Pokud celkový výsledek > 0, DM má vyplněnou konkurenci.
WHEN ISNULL(
     CASE
          WHEN EVIDENCE_KONKURENCE.KONKURENCE_PRODUKTY_CELKEM
               = EVIDENCE_KONKURENCE.KONKURENCE_PRODUKTY_VYPLNENO
          THEN NULLIF(EVIDENCE_KONKURENCE.VYHRAZENO, 0)
     END,
     DELKA_REGALU.VYHRAZENO
) > 0 THEN 1
""", },
        def column DTPRVNI_DOD { type: date, optional: true, description: "Datum první dodávky na dodacím místě: MIN(XXPRODEJE.DTPRVNI_DOD)", },
        def column POCET_PODPROD_DM { type: int, optional: true, description: """Počet zájmových podproduktů, které na dodacím místě mají tržbu 12M > 0:
COUNT(DISTINCT CASE WHEN XXPRODEJE.HDTRZBA_12M > 0 AND QXXMEZABC.VLVYZNAM_F > 0
      THEN XXPRODEJE.IDXXPODSKUPZBOZI END)
""", },
        def column POCET_PODPROD_KANAL { type: int, optional: true, description: """Počet zájmových podproduktů v kanálu s aktivním listingem k dnešnímu dni:
COUNT(DISTINCT ZBOZIADD.IDXXPODSKUPZBOZI) kde QXXMEZABC.VLVYZNAM_F > 0
""", },
        def column KONKURENCE_PRODUKTY_CELKEM { type: int, optional: true, description: "Počet produktů poslední návštěvy: COUNT(DISTINCT XXKONKNADM.IDSKUPZBOZI)", },
        def column KONKURENCE_PRODUKTY_VYPLNENO { type: int, optional: true, description: """Počet produktů poslední návštěvy s evidovanou konkurencí:
COUNT(DISTINCT CASE
     WHEN XXKONKURENT_D.NAZEV_KONKURENTA <> '(neurčený)'
          AND XXKONKURENT_Z.NAZEV_KONKURENTA <> '(neurčená)'
     THEN XXKONKNADM.IDSKUPZBOZI
END)
""", },
        def column VYHRAZENO { type: int, optional: true, description: """Celkový vyhrazený prostor na dodacím místě:
ISNULL(
     CASE
          WHEN EVIDENCE_KONKURENCE.KONKURENCE_PRODUKTY_CELKEM
               = EVIDENCE_KONKURENCE.KONKURENCE_PRODUKTY_VYPLNENO
          THEN NULLIF(EVIDENCE_KONKURENCE.VYHRAZENO, 0)
     END,
     DELKA_REGALU.VYHRAZENO
)
""", },
        def column HDTRZBA_12M_PODPROD { type: text, optional: true, description: "Skutečná tržba podproduktu na DM za posledních 12 měsíců", },
        def column HDNORMATIV_TRZBY { type: text, optional: true, description: "Cílová (normativní) tržba podproduktu na DM — určuje očekávanou úroveň prodejů. Zdroj: QXXMEZABC.HDNORMATIV_TRZBY_F (VLTYP_NASTAVENI = 22), jen zájmové podprodukty v kanálu.", },
        def column HDTRZBA_12M_DM { type: text, optional: true, description: "SUM ( HDTRZBA_12M_PODPROD ) Celkový součet prodejů za dodací místo", },
        def column HDNORMATIV_TRZBY_DM { type: text, optional: true, description: "SUM ( HDNORMATIV_TRZBY ) Celkový součet normativů tržby za dodací místo", },
        def column HDTRZBA_NORMATIV { type: text, optional: true, description: "Výpočtové pole podle pravidla: HDNORMATIV_TRZBY / 100 * ( HDTRZBA_12M_DM / ( HDNORMATIV_TRZBY_DM / 100 ) )", },
        def column VLPODPROD_NADNORMATIV { type: int, optional: true, description: "Výpočtové pole: 1 = nadnormativní (HDTRZBA_12M_PODPROD >= HDTRZBA_NORMATIV), 0 = pod normou, NULL = nedefinováno", },
        def column HDTRZBA_NORMATIV_UPRAV { type: text, optional: true, description: "Výpočtové pole podle pravidla: WHEN ISNULL ( HDTRZBA_NORMATIV, 0) <= 0 THEN 0 WHEN HDTRZBA_12M_PODPROD > HDTRZBA_NORMATIV AND HDTRZBA_12M_PODPROD / HDTRZBA_NORMATIV > 1.33 THEN HDTRZBA_NORMATIV * 1.33 ELSE HDTRZBA_12M_PODPROD", },
        def column HDTRZBA_POTENCIAL_DM { type: text, optional: true, description: "WHEN ISNULL(HDTRZBA_12M_PODPROD,0) = 0 THEN 0 ELSE SUM(HDTRZBA_NORMATIV_UPRAV) pro VLPODPROD_NADNORMATIV = 1 za dodací místo / SUM(HDNORMATIV_TRZBY / 100) pro VLPODPROD_NADNORMATIV = 1 za dodací místo", },
        def column HDTRZBA_CILOVYNORMATIV_PODPROD { type: text, optional: true, description: "HDTRZBA_POTENCIAL_DM * HDNORMATIV_TRZBY / 100 — cílová tržba podproduktu odvozená z celkového potenciálu DM", },
        def column HDTRZBA_POTENCIAL_PODPROD { type: text, optional: true, description: "HDTRZBA_CILOVYNORMATIV_PODPROD - HDTRZBA_12M_PODPROD — rezerva tržby podproduktu (kladná = prostor pro růst, záporná = překonává cíl)", },
        def column HDTRZBA_VYTEZNOST_PODPROD { type: text, optional: true, description: "HDTRZBA_12M_PODPROD / HDTRZBA_CILOVYNORMATIV_PODPROD * 100 zaokrouhlené na 1 desetinné číslo", },
    ]
}

def table XXVYPADKYZASOB { description: """Evidence zásob artiklů na skladech.
""", primaryKey: ["id_zásoby_artiklu"],
    columns: [
