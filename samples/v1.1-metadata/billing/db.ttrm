        def column IDSKUPUZIV_R { type: int, optional: true, description: "FK na nadřazené (řídící) funkční místo. NULL = kořenové funkční místo bez nadřízeného.", },
        def column NAZEV_SKUP_UZIV_R { type: text, optional: true, description: "Název nadřízeného funkčního místa (denormalizovaný)", },
    ]
}

