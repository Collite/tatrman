        def column VLSTAVUO { type: int, optional: true, description: "Stav účetního období (0 = otevřené)", },
        def column dtObd_PrvniDen { type: datetime, optional: true, description: "První den účetního období", },
        def column dtObd_PoslDen { type: datetime, optional: true, description: "Poslední den účetního období", },
    ]
}

