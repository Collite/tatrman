        def column HDCCENAVAL { type: text, optional: true, description: "Celková cena položky", },
    ]
}

def table QSKUPUZIV { description: """Strom funkčních míst (pozic). Každý řádek = podřízené místo + jeho nadřízené místo.
""", primaryKey: ["id_podřízeného_funkčního_místa"],
    columns: [
