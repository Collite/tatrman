package billing.invoicing

schema er namespace entity

def relation artikl_produkt { description: "Artikl patří pod nadřazený produkt",
    from: er.entity.artikl, to: billing.products.er.entity.produkt,
    cardinality: { from: "0..*", to: "0..1" },
    join: [{ from: er.entity.artikl.id_produktu, to: billing.products.er.entity.produkt.id_produktu }]
}