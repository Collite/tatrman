package billing.invoicing

schema er namespace entity

def relation artikl_podprodukt { description: "Artikl patří pod nadřazený podprodukt",
    from: er.entity.artikl, to: billing.products.er.entity.podprodukt,
    cardinality: { from: "0..*", to: "1" },
    join: [{ from: er.entity.artikl.id_podproduktu, to: billing.products.er.entity.podprodukt.id_podproduktu }]
}