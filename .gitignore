# Conformance harness: the TS dumps under tests/conformance/out-ts{,-sem}/ are
# committed as the GOLDEN baseline — CI regenerates them and asserts `git diff`
# is clean, so any change to TS dump output surfaces in review (catches TS-side
# drift the cross-language diff alone would miss). Kotlin dumps stay generated
# (under build/, ignored above) and are diffed against this baseline.
# The Python dumps (out-py{,-sem}/) are CI-only artifacts diffed against the TS
# golden — never committed (only out-ts{,-sem}/ is the reference).
tests/conformance/out-py/
tests/conformance/out-py-sem/

# OS / editor cruft
.DS_Store
.idea/
.kotlin/

# Python (ttr-parser — packages/python/ttr-parser/)
# Generated parser (D4: regenerated from TTR.g4 at build time, never committed)
packages/python/ttr-parser/src/ttr_parser/_generated/
# Stock CNC vocab — copied at build from the canonical @modeler/semantics copy
# (D4: single source of truth, no committed duplicate; shipped in the wheel).
packages/python/ttr-parser/src/ttr_parser/semantics/stock/
# Hatchling build hook + build outputs
packages/python/ttr-parser/dist/
packages/python/ttr-parser/build/
packages/python/ttr-parser/*.egg-info/
packages/python/ttr-parser/.pytest_cache/
packages/python/ttr-parser/.mypy_cache/
packages/python/ttr-parser/.ruff_cache/
packages/python/ttr-parser/.venv/
